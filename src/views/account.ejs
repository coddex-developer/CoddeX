<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: 'Minha conta · CoddeX', pageDescription: 'Painel do usuário' }) %>
</head>

<body class="d-flex flex-column min-vh-100">
  <nav class="navbar sticky-top" data-bs-theme="dark">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 38px;">
        <span class="fw-bold gradient-text d-none d-sm-inline">CoddeX</span>
      </a>
      <div class="d-flex align-items-center gap-2">
        <a href="/" class="btn btn-outline-light btn-sm"><i class="bi bi-house me-1"></i>Site</a>
        <a href="/logout" class="btn btn-outline-light btn-sm text-danger"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1">
    <div class="container py-5" style="max-width: 900px;">

      <!-- Cabeçalho -->
      <div class="glass p-4 mb-4 d-flex align-items-center gap-3 flex-wrap">
        <div class="account-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div class="flex-grow-1">
          <h1 class="h4 mb-1">Olá, <%= user.name %>!</h1>
          <p class="text-muted-2 mb-0"><i class="bi bi-envelope me-1"></i><%= user.email %></p>
        </div>
        <% if (user.emailVerified) { %>
          <span class="badge rounded-pill" style="background:rgba(34,197,94,.15);color:#86efac;border:1px solid rgba(34,197,94,.4);">
            <i class="bi bi-patch-check-fill me-1"></i>E-mail verificado
          </span>
        <% } %>
      </div>

      <!-- Projetos que curti -->
      <h2 class="h5 mb-3"><i class="bi bi-heart-fill me-2" style="color: var(--danger);"></i>Projetos que curti</h2>
      <% if (likedProjects && likedProjects.length > 0) { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3 mb-4">
          <% likedProjects.forEach(p => { %>
            <div class="col">
              <a href="/projeto/<%= p._id %>" class="text-decoration-none">
                <div class="card h-100">
                  <img src="<%= p.imagePj %>" alt="<%= p.titlePj %>" style="height:140px;object-fit:cover;border-radius:var(--radius) var(--radius) 0 0;">
                  <div class="card-body">
                    <h6 class="fw-bold mb-0"><%= p.titlePj %></h6>
                  </div>
                </div>
              </a>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="glass p-4 mb-4 text-muted-2">
          Você ainda não curtiu nenhum projeto. <a href="/#projetos" style="color:var(--accent-2);">Explore os projetos</a>.
        </div>
      <% } %>

      <!-- Recurso futuro -->
      <div class="card p-2">
        <div class="card-body">
          <i class="bi bi-chat-dots-fill display-6 mb-2" style="color: var(--info);"></i>
          <h5 class="fw-bold">Minhas conversas</h5>
          <p class="text-secondary mb-0">Em breve você poderá falar diretamente comigo por aqui.</p>
        </div>
      </div>

    </div>
  </main>

  <footer class="text-center py-3 mt-auto">
    <small>&copy; <%= new Date().getFullYear() %> · CoddeX Developer</small>
  </footer>
</body>

</html>
