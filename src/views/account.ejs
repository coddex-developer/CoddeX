<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: 'Minha conta · CoddeX', pageDescription: 'Painel do usuário' }) %>
</head>

<body class="d-flex flex-column min-vh-100" style="background: var(--bg);">
  
  <div class="container-fluid py-4 flex-grow-1">
    <div class="row gx-4">
      
      <!-- Sidebar (Desktop/Mobile) -->
      <div class="col-md-4 col-lg-3">
        <%- include('fragments/accountSidebar', { user: user, currentPath: '/account' }) %>
      </div>

      <!-- Main Content -->
      <div class="col-md-8 col-lg-9 mt-4 mt-md-0">
        
        <div class="p-4 mb-4 d-flex align-items-center justify-content-between flex-wrap rounded shadow-sm" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
          <div>
            <h1 class="h3 fw-bold mb-1" style="color: var(--text);">Painel do Usuário</h1>
            <p class="mb-0" style="color: var(--text-muted); font-weight: 500;">Bem-vindo de volta, <%= user.name %></p>
          </div>
          <% if (user.emailVerified) { %>
            <span class="badge rounded-pill mt-2 mt-sm-0" style="background:rgba(34,197,94,.15);color:#86efac;border:1px solid rgba(34,197,94,.4); padding: 0.5rem 1rem;">
              <i class="bi bi-patch-check-fill me-2"></i>E-mail verificado
            </span>
          <% } %>
        </div>

        <!-- Notificações -->
        <h2 class="h5 mb-3 fw-bold" style="color: var(--text);"><i class="bi bi-bell-fill me-2" style="color: var(--warning);"></i>Notificações Recentes</h2>
        <% if (notifications && notifications.length > 0) { %>
          <div class="p-3 mb-5 d-flex flex-column gap-2 rounded shadow-sm" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
            <% notifications.forEach(notif => { %>
              <a href="<%= notif.link %>" class="text-decoration-none p-3 rounded d-flex align-items-center gap-3" style="background: var(--bg); border: 1px solid var(--border-strong); transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent-1)'" onmouseout="this.style.borderColor='var(--border-strong)'">
                <div class="bg-gradient d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width:40px;height:40px; color:var(--text);">
                  <i class="bi <%= notif.type === 'mention' ? 'bi-at fs-5' : notif.type === 'reply' ? 'bi-reply-fill fs-5' : 'bi-info-circle fs-5' %>"></i>
                </div>
                <div class="flex-grow-1 min-w-0">
                  <p class="mb-0 fw-semibold" style="color: var(--text);"><%= notif.text %></p>
                  <small style="color: var(--text-muted);"><%= new Date(notif.createdAt).toLocaleDateString('pt-BR') %> às <%= new Date(notif.createdAt).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %></small>
                </div>
                <% if (!notif.read) { %>
                  <div class="rounded-circle bg-danger flex-shrink-0" style="width: 10px; height: 10px; box-shadow: 0 0 10px var(--danger);"></div>
                <% } %>
              </a>
            <% }); %>
          </div>
        <% } else { %>
          <div class="p-5 mb-5 text-center rounded shadow-sm" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
            <i class="bi bi-bell-slash" style="font-size: 2.5rem; color: var(--text-muted);"></i>
            <h5 class="mt-3" style="color: var(--text);">Nenhuma notificação</h5>
            <p style="color: var(--text-muted);">Você está por dentro de tudo.</p>
          </div>
        <% } %>

        <!-- Projetos que curti -->
        <h2 class="h5 mb-3 fw-bold" style="color: var(--text);"><i class="bi bi-heart-fill me-2" style="color: var(--danger);"></i>Projetos que curti</h2>
        <% if (likedProjects && likedProjects.length > 0) { %>
          <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mb-5">
            <% likedProjects.forEach(p => { %>
              <div class="col">
                <a href="/projeto/<%= p._id %>" class="text-decoration-none">
                  <div class="card h-100" style="background: var(--surface-1); border: 1px solid var(--border-strong); transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent-1)'" onmouseout="this.style.borderColor='var(--border-strong)'">
                    <img src="<%= p.imagePj %>" alt="<%= p.titlePj %>" style="height:160px;object-fit:cover;border-radius:calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;">
                    <div class="card-body p-3">
                      <h6 class="fw-bold mb-0 text-truncate" style="color: var(--text);"><%= p.titlePj %></h6>
                    </div>
                  </div>
                </a>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="p-5 mb-5 text-center rounded shadow-sm" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
            <i class="bi bi-heart" style="font-size: 2.5rem; color: var(--text-muted);"></i>
            <h5 class="mt-3" style="color: var(--text);">Nenhuma curtida ainda</h5>
            <p style="color: var(--text-muted);">Explore o portfólio e salve seus favoritos.</p>
            <a href="/#projetos" class="btn btn-outline-light mt-2">Explorar Projetos</a>
          </div>
        <% } %>

      </div>
    </div>
  </div>

  <script>
    // Ativa os tooltips do bootstrap
    document.addEventListener("DOMContentLoaded", () => {
      const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
      const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl))
    });
  </script>
</body>
</html>
