<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: site.title + ' · Portfólio', pageDescription: site.subtitle }) %>

  <!-- Open Graph -->
  <meta property="og:title" content="<%= site.title %>">
  <meta property="og:description" content="<%= site.subtitle %>">
  <meta property="og:image" content="/assets/admin1.png">
  <meta property="og:url" content="https://coddex.store">
  <meta property="og:type" content="website">

  <link rel="stylesheet" href="/styles/style.css">

  <!-- Tawk.to Chat -->
<!--  <script type="text/javascript">
    var Tawk_API = Tawk_API || {}, Tawk_LoadStart = new Date();
    (function () {
      var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
