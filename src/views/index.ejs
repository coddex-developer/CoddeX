<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: site.title + ' · Portfólio', pageDescription: site.subtitle }) %>

  <!-- Open Graph -->
  <meta property="og:title" content="<%= site.title %>">
  <meta property="og:description" content="<%= site.subtitle %>">
  <meta property="og:image" content="/assets/admin1.png">
  <meta property="og:url" content="https://coddex.store">
  <meta property="og:type" content="website">

  <link rel="stylesheet" href="/styles/style.css">

  <!-- Tawk.to Chat -->
  <script type="text/javascript">
    var Tawk_API = Tawk_API || {}, Tawk_LoadStart = new Date();
    (function () {
      var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
      s1.async = true;
      s1.src = 'https://embed.tawk.to/67acff02825083258e1444a7/1ijts892a';
      s1.charset = 'UTF-8';
      s1.setAttribute('crossorigin', '*');
      s0.parentNode.insertBefore(s1, s0);
    })();
  </script>
</head>

<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg sticky-top" data-bs-theme="dark">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="#top">
        <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 38px;" />
        <span class="fw-bold gradient-text d-none d-sm-inline"><%= site.title %></span>
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto gap-1">
          <li class="nav-item"><a class="nav-link" href="#sobre"><i class="bi bi-person-circle me-1"></i>Sobre</a></li>
          <li class="nav-item"><a class="nav-link" href="#projetos"><i class="bi bi-code-slash me-1"></i>Projetos</a></li>
          <li class="nav-item"><a class="nav-link" href="#certificados"><i class="bi bi-mortarboard me-1"></i>Certificados</a></li>
          <li class="nav-item"><a class="nav-link" href="/blog"><i class="bi bi-journal-text me-1"></i>Blog</a></li>
          <li class="nav-item"><a class="nav-link" href="#contato"><i class="bi bi-envelope me-1"></i>Contato</a></li>
        </ul>
        <div class="d-flex gap-2 ms-lg-3 mt-2 mt-lg-0">
          <% if (currentUser) { %>
            <a class="btn btn-gradient btn-sm" href="/account"><i class="bi bi-person-circle me-1"></i>Minha conta</a>
          <% } else { %>
            <a class="btn btn-outline-light btn-sm" href="/login"><i class="bi bi-box-arrow-in-right me-1"></i>Entrar</a>
            <a class="btn btn-gradient btn-sm" href="/register"><i class="bi bi-person-plus me-1"></i>Criar conta</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header id="top" class="hero">
    <div class="hero-glow"></div>
    <div class="container position-relative text-center">
      <h1 class="hero-title mt-3" data-animate-bottom>
        <span class="gradient-text"><%= site.title %></span>
      </h1>
      <p class="hero-subtitle mx-auto mt-3" data-animate-bottom><%= site.subtitle %></p>
      <div class="d-flex gap-3 justify-content-center flex-wrap mt-4" data-animate-bottom>
        <a class="btn btn-gradient px-4 py-2" href="#contato"><i class="bi bi-send me-2"></i>Entrar em contato</a>
        <a class="btn btn-outline-light px-4 py-2" href="#projetos"><i class="bi bi-grid me-2"></i>Ver projetos</a>
      </div>
    </div>
  </header>

  <!-- Sobre -->
  <section id="sobre" class="py-5">
    <div class="container">
      <h2 class="section-title text-center" data-animate-bottom><%= site.titleAboutMe %></h2>
      <div class="about-box glass p-4 p-md-5 mx-auto mt-4 markdown-body" data-animate-bottom>
        <%- md(site.textAboutMe) %>
      </div>
    </div>
  </section>

  <!-- Projetos -->
  <section id="projetos" class="py-5">
    <div class="container">
      <h2 class="section-title text-center mb-5" data-animate-bottom>Projetos</h2>
      <div class="ig-feed">
        <% if (projects.length > 0) { %>
          <% projects.forEach(project => { %>
            <article class="ig-card" data-animate-bottom>
              <!-- Cabeçalho -->
              <header class="ig-head">
                <img class="ig-avatar" src="/assets/admin1.png" alt="<%= site.title %>">
                <span class="ig-user"><%= site.title %></span>
                <a href="<%= project.linkPj %>" target="_blank" rel="noopener" class="ig-live ms-auto" title="Ver ao vivo">
                  <i class="bi bi-box-arrow-up-right"></i>
                </a>
              </header>

              <!-- Mídia -->
              <a href="/projeto/<%= project._id %>" class="ig-media">
                <img src="<%= project.imagePj %>" alt="<%= project.titlePj %>" loading="lazy">
              </a>

              <!-- Ações -->
              <div class="ig-actions">
                <% if (currentUser) { %>
                  <form action="/projeto/<%= project._id %>/like" method="post" class="m-0">
                    <button class="ig-btn" type="submit" title="<%= project.likedByMe ? 'Descurtir' : 'Curtir' %>">
                      <i class="bi <%= project.likedByMe ? 'bi-heart-fill liked' : 'bi-heart' %>"></i>
                    </button>
                  </form>
                <% } else { %>
                  <a href="/login" class="ig-btn" title="Entre para curtir"><i class="bi bi-heart"></i></a>
                <% } %>
                <a href="/projeto/<%= project._id %>#comentarios" class="ig-btn ig-comment-btn" title="Comentários">
                  <i class="bi bi-chat"></i><span class="ig-count"><%= project.commentCount %></span>
                </a>
              </div>

              <!-- Corpo -->
              <div class="ig-body">
                <div class="ig-likes"><%= project.likeCount %> curtida<%= project.likeCount === 1 ? '' : 's' %></div>
                <div class="ig-caption">
                  <a href="/projeto/<%= project._id %>" class="ig-user text-decoration-none"><%= project.titlePj %></a>
                  <span class="ig-desc markdown-body"><%- md(project.descriptionPj) %></span>
                </div>
                <a href="/projeto/<%= project._id %>#comentarios" class="ig-comments-link">
                  <% if (project.commentCount > 0) { %>
                    Ver todos os <%= project.commentCount %> comentário<%= project.commentCount === 1 ? '' : 's' %>
                  <% } else { %>
                    Seja o primeiro a comentar
                  <% } %>
                </a>
              </div>
            </article>
          <% }); %>
        <% } else { %>
          <div class="empty-state glass mx-auto" data-animate-bottom>
            <i class="bi bi-folder2-open"></i>
            <p class="mb-0">Nenhum projeto foi postado até o momento!</p>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Certificados -->
  <section id="certificados" class="py-5">
    <div class="container">
      <h2 class="section-title text-center mb-5" data-animate-bottom>Certificados</h2>
    </div>
    <% if (certificates.length > 0) { %>
      <div class="certificate-rail" data-animate-bottom>
        <% certificates.forEach(certificate => { %>
          <div class="certificate-card">
            <img src="<%= certificate.image %>" alt="<%= certificate.title %>" loading="lazy">
            <div class="certificate-body">
              <h6><i class="bi bi-patch-check-fill me-1"></i><%= certificate.title %></h6>
              <a href="<%= certificate.url %>" target="_blank" rel="noopener" class="btn btn-outline-light btn-sm w-100">
                Visualizar
              </a>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="container">
        <div class="empty-state glass mx-auto" data-animate-bottom>
          <i class="bi bi-mortarboard"></i>
          <p class="mb-0">Nenhum certificado foi postado até o momento!</p>
        </div>
      </div>
    <% } %>
  </section>

  <!-- Serviços / Timeline -->
  <section id="experiencia" class="py-5">
    <div class="container">
      <h2 class="section-title text-center" data-animate-bottom>Nosso trabalho</h2>
      <p class="text-center text-muted-2 mb-5 mx-auto" style="max-width: 640px;" data-animate-bottom>
        A CoddeX Developer investe tempo e recursos para garantir a mais moderna tecnologia para o seu negócio.
      </p>
      <div class="timeline">
        <div class="timeline-item glass" data-animate-bottom>
          <h5><i class="bi bi-cursor-fill me-2"></i>Páginas na web</h5>
          <p class="mb-0">Sites e páginas para aumentar a visibilidade da sua empresa, com equipe especializada em desenvolvimento e mentoria.</p>
        </div>
        <div class="timeline-item glass" data-animate-bottom>
          <h5><i class="bi bi-diagram-3-fill me-2"></i>Sistemas claros e eficientes</h5>
          <p class="mb-0">Projetos claros e eficientes que atendem às necessidades dos seus clientes e às expectativas dos usuários finais.</p>
        </div>
        <div class="timeline-item glass" data-animate-bottom>
          <h5><i class="bi bi-shield-check me-2"></i>Backup e relatórios</h5>
          <p class="mb-0">Relatórios detalhados, acompanhamento contínuo e mentoria especializada sobre o site ou sistema desenvolvido.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contato -->
  <section id="contato" class="py-5">
    <div class="container">
      <div class="contact-box glass mx-auto p-4 p-md-5" data-animate-bottom>
        <h2 class="section-title text-center mb-4">Entre em Contato</h2>
        <form id="contactForm" action="/sms/env" method="POST">
          <div class="mb-3">
            <label for="name" class="form-label">Nome</label>
            <input type="text" class="form-control" name="name" id="name" placeholder="Digite seu nome" required>
          </div>
          <div class="mb-3">
            <label for="zap" class="form-label">WhatsApp</label>
            <input type="text" class="form-control" id="zap" name="phone" placeholder="(DDD) 9 9999-9999" required>
            <small id="phoneError" class="text-danger" style="display: none;">Insira um número de WhatsApp válido com DDD.</small>
          </div>
          <div class="mb-3">
            <label for="email" class="form-label">E-mail</label>
            <input type="email" name="email" class="form-control" id="email" placeholder="Digite seu e-mail" required>
          </div>
          <div class="mb-3">
            <label for="mensagem" class="form-label">Mensagem</label>
            <textarea class="form-control" id="mensagem" name="messenger" rows="4" placeholder="Digite sua mensagem" required></textarea>
          </div>
          <button type="submit" class="btn btn-gradient w-100"><i class="bi bi-send me-2"></i>Enviar</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-4">
    <div class="container text-center">
      <p class="mb-2">© <%= new Date().getFullYear() %> <%= site.title %> — Todos os direitos reservados</p>
      <div class="social-links">
        <% if (site.social && site.social.github) { %>
          <a href="<%= site.social.github %>" target="_blank" rel="noopener" aria-label="GitHub"><i class="bi bi-github"></i></a>
        <% } %>
        <% if (site.social && site.social.linkedin) { %>
          <a href="<%= site.social.linkedin %>" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
        <% } %>
        <% if (site.social && site.social.instagram) { %>
          <a href="<%= site.social.instagram %>" target="_blank" rel="noopener" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
        <% } %>
        <% if (site.social && site.social.whatsapp) { %>
          <a href="<%= site.social.whatsapp %>" target="_blank" rel="noopener" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
        <% } %>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('zap').addEventListener('input', function (e) {
      let phone = e.target.value.replace(/\D/g, '');
      if (phone.length > 2) {
        phone = `(${phone.substring(0, 2)}) ${phone.substring(2, 3)} ${phone.substring(3, 7)}-${phone.substring(7, 11)}`;
      }
      e.target.value = phone;
    });

    document.getElementById('contactForm').addEventListener('submit', function (e) {
      const phoneInput = document.getElementById('zap');
      const phoneError = document.getElementById('phoneError');
      const phoneRegex = /^\(\d{2}\)\s?\d\s?\d{4}-\d{4}$/;
      if (!phoneRegex.test(phoneInput.value)) {
        phoneError.style.display = 'block';
        e.preventDefault();
      } else {
        phoneError.style.display = 'none';
        phoneInput.value = phoneInput.value.replace(/\D/g, '');
      }
    });
  </script>

  <script src="./script/index.js" type="module"></script>
</body>

</html>
