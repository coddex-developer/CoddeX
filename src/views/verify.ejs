<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: 'Verificar e-mail · CoddeX', pageDescription: 'Confirme seu e-mail' }) %>
  <link rel="stylesheet" href="/styles/admin.css">
</head>

<body class="login-page">
  <div class="login-glow"></div>

  <div class="login-card glass">
    <img src="/assets/admin1.png" class="login-logo" alt="CoddeX">
    <h1 class="login-title gradient-text">Confirme seu e-mail</h1>
    <p class="login-subtitle">Enviamos um código de 6 dígitos para<br><strong><%= email %></strong></p>

    <% if (error) { %>
      <div class="alert alert-warning py-2 mb-0"><i class="bi bi-exclamation-triangle me-1"></i><%= error %></div>
    <% } %>
    <% if (info) { %>
      <div class="alert py-2 mb-0" style="background:rgba(34,211,238,.12);border-color:rgba(34,211,238,.3);color:#a5f3fc;"><i class="bi bi-check-circle me-1"></i><%= info %></div>
    <% } %>

    <form class="ajax-form" action="/verify" method="post">
      <input type="hidden" name="email" value="<%= email %>">
      <div class="field">
        <label for="code" class="form-label text-center w-100"><i class="bi bi-shield-lock me-1"></i>Código de verificação</label>
        <input type="text" class="form-control text-center" name="code" id="code" inputmode="numeric" pattern="[0-9]*"
          maxlength="6" autocomplete="one-time-code" required
          style="letter-spacing:.6rem;font-size:1.6rem;font-weight:700;">
      </div>
      <button class="btn btn-gradient w-100 mt-2" type="submit"><i class="bi bi-check2-circle me-2"></i>Verificar</button>
    </form>

    <form action="/verify/resend" method="post" class="ajax-form mt-1">
      <input type="hidden" name="email" value="<%= email %>">
      <button type="submit" class="btn btn-link p-0 back-link" style="text-decoration:none;">
        <i class="bi bi-arrow-clockwise me-1"></i>Reenviar código
      </button>
    </form>

    <a href="/" class="back-link"><i class="bi bi-arrow-left me-1"></i>Voltar ao site</a>
  </div>
</body>

</html>
