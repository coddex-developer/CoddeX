<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 800px;">
  <!-- Cabeçalho -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar aos Projetos
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Editar Projeto</h1>
      <p class="text-muted mb-0">Atualize as informações do projeto: <span class="text-white fw-bold"><%= project.titlePj %></span></p>
    </div>
  </div>

  <form class="ajax-form" action="/admin/dashboard/editPage/allProjects/<%= project.id %>/updated" enctype="multipart/form-data" method="POST">
    
    <!-- Imagem de Capa Atual / Nova -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-image me-2" style="color: var(--accent-2);"></i>Capa do Projeto</h2>
      
      <div class="row align-items-center g-4">
        <div class="col-md-5 text-center">
          <p class="text-muted small text-uppercase fw-bold mb-2">Capa Atual</p>
          <img src="<%= project.imagePj %>" class="img-fluid rounded-4 shadow-sm w-100" style="object-fit: cover; max-height: 180px; border: 1px solid rgba(255,255,255,0.1);" alt="<%= project.titlePj %>">
        </div>
        <div class="col-md-7">
          <label class="upload-drop d-flex flex-column align-items-center justify-content-center text-center w-100" for="file" style="height: 180px; background: rgba(0, 0, 0, 0.4); border: 1px dashed rgba(0, 240, 255, 0.3); border-radius: var(--radius); cursor: pointer; transition: all 0.3s ease;">
            <i class="bi bi-cloud-arrow-up fs-2 mb-2 text-accent-2"></i>
            <span class="text-white fw-medium small">Trocar Imagem de Capa</span>
            <small class="text-muted mt-1">Opcional (Deixe em branco para manter)</small>
            <input type="file" id="file" name="imageFile" accept="image/*" hidden data-preview="#coverPreview">
          </label>
        </div>
      </div>
      
      <div class="text-center mt-4">
        <img id="coverPreview" class="img-preview mb-0 rounded-4 shadow-sm w-100" style="display:none; max-height: 300px; object-fit: cover; border: 2px solid var(--accent-2);" alt="Pré-visualização da nova capa">
      </div>
    </div>

    <!-- Informacoes Principais -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-text-paragraph me-2" style="color: var(--accent-1);"></i>Informações do Projeto</h2>
      
      <div class="row g-4">
        <div class="col-md-12">
          <label for="title" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Título do Projeto</label>
          <input type="text" class="form-control" id="title" name="titlePj" value="<%= project.titlePj %>" required>
        </div>
        
        <div class="col-md-12">
          <label for="subtitle" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Pequena Descrição / Slogan</label>
          <textarea class="form-control" id="subtitle" name="subtitlePj" rows="2" required><%= project.subtitlePj %></textarea>
        </div>
      </div>
    </div>

    <!-- Links do Projeto -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-link-45deg me-2" style="color: var(--warning);"></i>Links Externos</h2>
      
      <div class="row g-4">
        <div class="col-md-6">
          <label for="gitLink" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-github me-1"></i>Link do Repositório</label>
          <input type="url" class="form-control" id="gitLink" name="gitLinkPj" value="<%= project.gitLinkPj %>">
        </div>
        
        <div class="col-md-6">
          <label for="siteLink" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-globe me-1"></i>Link do Projeto (Site)</label>
          <input type="url" class="form-control" id="siteLink" name="siteLinkPj" value="<%= project.siteLinkPj %>">
        </div>
      </div>
    </div>

    <!-- Botoes Finais -->
    <div class="d-flex justify-content-between align-items-center mt-4">
      <form action="/admin/dashboard/editPage/CreateProjects/allProjects/<%= project.id %>" method="post" class="m-0 ajax-form" data-confirm="Excluir o projeto '<%= project.titlePj %>'? Esta ação não pode ser desfeita." data-confirm-title="Excluir Projeto" data-confirm-btn="Excluir">
        <button class="btn btn-outline-danger px-4 py-2" type="button" onclick="this.closest('form').submit()">
          <i class="bi bi-trash3-fill me-2"></i>Excluir Projeto
        </button>
      </form>
      
      <div class="d-flex gap-3">
        <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="btn btn-secondary px-4 py-2">Cancelar</a>
        <button type="submit" class="btn btn-gradient px-5 py-2"><i class="bi bi-save me-2"></i>Salvar Alterações</button>
      </div>
    </div>
  </form>
</div>

<%- include('fragments/footer') %>