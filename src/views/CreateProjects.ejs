<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 800px;">
  <!-- Cabeçalho -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar aos Projetos
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Novo Projeto</h1>
      <p class="text-muted mb-0">Adicione um novo trabalho ao seu portfólio.</p>
    </div>
  </div>

  <form class="ajax-form" action="/admin/dashboard/editPage" enctype="multipart/form-data" method="POST">
    <!-- Imagem de Capa -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-image me-2" style="color: var(--accent-2);"></i>Capa do Projeto</h2>
      
      <label class="upload-drop d-flex flex-column align-items-center justify-content-center text-center mb-3" for="file" style="min-height: 180px; background: rgba(0, 0, 0, 0.4); border: 1px dashed rgba(0, 240, 255, 0.3); border-radius: var(--radius); cursor: pointer; transition: all 0.3s ease;">
        <i class="bi bi-cloud-arrow-up fs-1 mb-2 text-accent-2"></i>
        <span class="text-white fw-medium">Fazer upload da imagem (Obrigatório)</span>
        <small class="text-muted mt-1">Recomendado: 1200x800px (JPG/PNG)</small>
        <input type="file" id="file" name="imageFile" accept="image/*" required hidden data-preview="#coverPreview">
      </label>
      
      <div class="text-center">
        <img id="coverPreview" class="img-preview mb-0 rounded-4 shadow-sm w-100" style="display:none; max-height: 300px; object-fit: cover;" alt="Pré-visualização da capa">
      </div>
    </div>

    <!-- Informacoes Principais -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-text-paragraph me-2" style="color: var(--accent-1);"></i>Informações do Projeto</h2>
      
      <div class="row g-4">
        <div class="col-md-12">
          <label for="title" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Título do Projeto</label>
          <input type="text" class="form-control" id="title" name="titlePj" placeholder="Ex: E-commerce Moderno" required>
        </div>
        
        <div class="col-md-12">
          <label for="subtitle" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Pequena Descrição / Slogan</label>
          <textarea class="form-control" id="subtitle" name="subtitlePj" rows="2" placeholder="Descreva brevemente a essência do projeto" required></textarea>
        </div>
      </div>
    </div>

    <!-- Links do Projeto -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-link-45deg me-2" style="color: var(--warning);"></i>Links Externos</h2>
      
      <div class="row g-4">
        <div class="col-md-6">
          <label for="gitLink" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-github me-1"></i>Link do Repositório</label>
          <input type="url" class="form-control" id="gitLink" name="gitLinkPj" placeholder="https://github.com/...">
        </div>
        
        <div class="col-md-6">
          <label for="siteLink" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-globe me-1"></i>Link do Projeto (Site)</label>
          <input type="url" class="form-control" id="siteLink" name="siteLinkPj" placeholder="https://seudominio.com">
        </div>
      </div>
    </div>

    <!-- Botoes Finais -->
    <div class="d-flex justify-content-end gap-3 mt-4">
      <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="btn btn-secondary px-4 py-2">Cancelar</a>
      <button type="submit" class="btn btn-gradient px-5 py-2"><i class="bi bi-rocket-takeoff me-2"></i>Publicar Projeto</button>
    </div>
  </form>
</div>

<%- include('fragments/footer') %>