<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 800px;">
  <!-- Cabeçalho -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard/editPage/my-certificates" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar aos Certificados
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Editar Certificado</h1>
      <p class="text-muted mb-0">Atualize as informações do certificado: <span class="text-white fw-bold"><%= certificate.title %></span></p>
    </div>
  </div>

  <form class="ajax-form" action="/admin/dashboard/editPage/my-certificates/editCertificate/<%= certificate.id %>/update" enctype="multipart/form-data" method="POST">
    
    <!-- Imagem Atual / Nova -->
    <div class="glass-panel p-4 mb-4 border-0">
      <h2 class="h5 mb-4 text-white fw-bold"><i class="bi bi-image me-2" style="color: var(--warning);"></i>Imagem do Certificado</h2>
      
      <div class="row align-items-center g-4">
        <div class="col-md-5 text-center">
          <p class="text-muted small text-uppercase fw-bold mb-2">Imagem Atual</p>
          <div style="background: #000; padding: 0.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
            <img src="<%= certificate.image %>" class="img-fluid w-100" style="object-fit: contain; max-height: 160px;" alt="<%= certificate.title %>">
          </div>
        </div>
        <div class="col-md-7">
          <label class="upload-drop d-flex flex-column align-items-center justify-content-center text-center w-100" for="file" style="height: 180px; background: rgba(0, 0, 0, 0.4); border: 1px dashed rgba(255, 138, 0, 0.3); border-radius: var(--radius); cursor: pointer; transition: all 0.3s ease;">
            <i class="bi bi-cloud-arrow-up fs-2 mb-2 text-warning"></i>
            <span class="text-white fw-medium small">Trocar Imagem</span>
            <small class="text-muted mt-1">Opcional (Deixe em branco para manter)</small>
            <input type="file" id="file" name="imageFile" accept="image/*" hidden data-preview="#coverPreview">
          </label>
        </div>
      </div>
      
      <div class="text-center mt-4">
        <img id="coverPreview" class="img-preview mb-0 rounded-4 shadow-sm w-100" style="display:none; max-height: 350px; object-fit: contain; background: #000; border: 2px solid var(--warning);" alt="Pré-visualização da nova imagem">
      </div>
    </div>

    <!-- Titulo -->
    <div class="glass-panel p-4 mb-4 border-0">
      <div class="row g-4">
        <div class="col-md-12">
          <label for="title" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-text-paragraph me-1"></i>Título do Certificado</label>
          <input type="text" class="form-control" id="title" name="title" value="<%= certificate.title %>" required>
        </div>
        <div class="col-md-12 mt-3">
          <label for="url" class="form-label text-uppercase text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-link-45deg me-1"></i>URL / Link do Certificado</label>
          <input type="url" class="form-control" id="url" name="url" value="<%= certificate.url %>" required>
        </div>
      </div>
    </div>

    <!-- Botoes Finais -->
    <div class="d-flex justify-content-between align-items-center mt-4">
      <form action="/admin/dashboard/editPage/my-certificates/<%= certificate.id %>" method="post" class="m-0 ajax-form" data-confirm="Excluir o certificado '<%= certificate.title %>'? Esta ação não pode ser desfeita." data-confirm-title="Excluir Certificado" data-confirm-btn="Excluir">
        <button class="btn btn-outline-danger px-4 py-2" type="button" onclick="this.closest('form').submit()">
          <i class="bi bi-trash3-fill me-2"></i>Excluir
        </button>
      </form>
      
      <div class="d-flex gap-3">
        <a href="/admin/dashboard/editPage/my-certificates" class="btn btn-secondary px-4 py-2">Cancelar</a>
        <button type="submit" class="btn btn-gradient px-5 py-2" style="background: linear-gradient(135deg, var(--warning) 0%, #ff8a00 100%);"><i class="bi bi-save me-2"></i>Salvar Alterações</button>
      </div>
    </div>
  </form>
</div>

<%- include('fragments/footer') %>