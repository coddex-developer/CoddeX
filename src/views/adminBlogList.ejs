<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 820px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-journal-text me-2 gradient-text"></i>Blog</h1>
    <div class="d-flex gap-2">
      <a href="/admin/dashboard" class="btn btn-outline-light btn-sm"><i class="bi bi-house-fill me-1"></i>Início</a>
      <a href="/admin/dashboard/blog/new" class="btn btn-gradient btn-sm"><i class="bi bi-plus-lg me-1"></i>Novo artigo</a>
    </div>
  </div>

  <% if (posts.length === 0) { %>
    <div class="glass p-4 text-center text-muted-2">Nenhum artigo ainda. Crie o primeiro!</div>
  <% } else { %>
    <div class="d-flex flex-column gap-2">
      <% posts.forEach(post => { %>
        <div class="glass p-3 d-flex align-items-center gap-3">
          <% if (post.coverImage) { %>
            <img src="<%= post.coverImage %>" alt="" style="width:64px;height:48px;object-fit:cover;border-radius:8px;">
          <% } else { %>
            <i class="bi bi-file-earmark-text fs-3 text-muted-2"></i>
          <% } %>
          <div class="flex-grow-1 min-w-0">
            <div class="d-flex align-items-center gap-2">
              <strong class="text-truncate"><%= post.title %></strong>
              <% if (post.published) { %>
                <span class="badge" style="background:rgba(34,197,94,.15);color:#86efac;border:1px solid rgba(34,197,94,.4);">publicado</span>
              <% } else { %>
                <span class="badge bg-secondary">rascunho</span>
              <% } %>
            </div>
            <small class="text-muted-2"><%= new Date(post.createdAt).toLocaleDateString('pt-BR') %> · /blog/<%= post.slug %></small>
          </div>
          <a href="/admin/dashboard/blog/<%= post._id %>/edit" class="btn btn-secondary btn-sm rounded-pill"><i class="bi bi-pencil-fill"></i></a>
          <form action="/admin/dashboard/blog/<%= post._id %>/delete" method="post" class="m-0"
            data-confirm="Excluir o artigo '<%= post.title %>'? Esta ação não pode ser desfeita." data-confirm-title="Excluir artigo" data-confirm-btn="Excluir">
            <button class="btn btn-danger btn-sm rounded-pill"><i class="bi bi-trash-fill"></i></button>
          </form>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('fragments/footer') %>
