<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<%- include('fragments/header') %>

<!-- EasyMDE (editor markdown com preview ao vivo) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
<script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>

<div class="container py-5" style="max-width: 760px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Configurar site</h1>
    <a href="/admin/dashboard" class="btn btn-outline-light btn-sm"><i class="bi bi-house-fill me-1"></i>Início</a>
  </div>

  <form class="ajax-form" action="/admin/dashboard/editPage/save" method="POST">

    <!-- Conteúdo principal -->
    <div class="glass p-4 mb-4">
      <h2 class="h5 mb-3"><i class="bi bi-fonts me-2 gradient-text"></i>Conteúdo</h2>

      <div class="mb-3">
        <label for="title" class="form-label">Título</label>
        <input type="text" class="form-control" id="title" name="titleForm" value="<%= site.title %>" required>
      </div>

      <div class="mb-3">
        <label for="subtitle" class="form-label">Subtítulo / slogan</label>
        <textarea class="form-control" id="subtitle" name="subtitleForm" rows="2" required><%= site.subtitle %></textarea>
      </div>

      <div class="mb-3">
        <label for="aboutTitle" class="form-label">Título "Sobre mim"</label>
        <input type="text" class="form-control" id="aboutTitle" name="titleAboutMeForm" value="<%= site.titleAboutMe %>" required>
      </div>

      <div class="mb-1">
        <label for="aboutText" class="form-label">Texto "Sobre mim" <span class="text-muted-2">(suporta markdown)</span></label>
        <textarea class="form-control" id="aboutText" name="textAboutMeForm" required><%= site.textAboutMe %></textarea>
      </div>
    </div>

    <!-- Aviso: configurações movidas -->
    <div class="glass p-3 mb-4 d-flex align-items-center gap-3">
      <i class="bi bi-info-circle fs-4 gradient-text"></i>
      <div class="flex-grow-1 small text-muted-2">
        Redes sociais, e-mail (SMTP) e Cloudinary agora ficam em
        <a href="/admin/dashboard/adminProfile" style="color:var(--accent-2);">Perfil & Configurações</a>.
      </div>
    </div>

    <!-- Atalhos -->
    <div class="d-grid gap-2 mb-4">
      <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="btn btn-outline-light text-start">
        <i class="bi bi-window-stack me-2"></i>Gerenciar projetos
      </a>
      <a href="/admin/dashboard/editPage/my-certificates" class="btn btn-outline-light text-start">
        <i class="bi bi-award-fill me-2"></i>Gerenciar certificados
      </a>
    </div>

    <button type="submit" class="btn btn-gradient w-100"><i class="bi bi-save me-2"></i>Salvar alterações</button>
  </form>
</div>

<script>
  new EasyMDE({
    element: document.getElementById("aboutText"),
    spellChecker: false,
    minHeight: "160px",
    status: false,
    toolbar: ["bold", "italic", "heading", "|", "quote", "unordered-list", "ordered-list", "|", "link", "preview", "guide"]
  });
</script>


<style>
  .ql-toolbar { background: var(--surface-2); border-color: var(--border) !important; border-radius: 8px 8px 0 0; }
  .ql-container { border-color: var(--border) !important; font-family: 'Roboto', sans-serif; font-size: 1rem; }
  .ql-editor { color: var(--text); }
  .ql-snow .ql-stroke { stroke: var(--text); }
  .ql-snow .ql-fill { fill: var(--text); }
  .ql-snow .ql-picker { color: var(--text); }
</style>
<script>
  var quilltextAboutMeForm = new Quill('#editor-container-textAboutMeForm', {
    theme: 'snow',
    placeholder: 'Escreva aqui...',
    modules: {
      toolbar: [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        ['blockquote', 'code-block'],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        ['link', 'clean']
      ]
    }
  });

  document.querySelector('.ajax-form').addEventListener('submit', function() {
    document.getElementById('textAboutMeForm').value = quilltextAboutMeForm.root.innerHTML;
  });
</script>

<%- include('fragments/footer') %>
