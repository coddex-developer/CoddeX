<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: project.titlePj + ' · CoddeX', pageDescription: project.titlePj }) %>
  <link rel="stylesheet" href="/styles/style.css">
</head>

<body class="d-flex flex-column min-vh-100">
  <nav class="navbar sticky-top" data-bs-theme="dark">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 38px;">
        <span class="fw-bold gradient-text d-none d-sm-inline">CoddeX</span>
      </a>
      <div class="d-flex align-items-center gap-2">
        <a href="/#projetos" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i>Projetos</a>
        <% if (currentUser) { %>
          <a href="/account" class="btn btn-gradient btn-sm"><i class="bi bi-person-circle me-1"></i>Minha conta</a>
        <% } else { %>
          <a href="/login" class="btn btn-gradient btn-sm"><i class="bi bi-box-arrow-in-right me-1"></i>Entrar</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1">
    <div class="container py-5" style="max-width: 820px;">

      <article class="glass overflow-hidden mb-4">
        <img src="<%= project.imagePj %>" alt="<%= project.titlePj %>" style="width:100%; max-height:360px; object-fit:cover;">
        <div class="p-4 p-md-5">
          <h1 class="section-title gradient-text mb-3"><%= project.titlePj %></h1>
          <div class="markdown-body mb-4"><%- md(project.descriptionPj) %></div>

          <div class="d-flex flex-wrap gap-2 align-items-center">
            <!-- Curtir -->
            <% if (currentUser) { %>
              <form action="/projeto/<%= project.id %>/like" method="post" class="m-0">
                <button class="btn <%= likedByMe ? 'btn-gradient' : 'btn-outline-light' %>" type="submit">
                  <i class="bi <%= likedByMe ? 'bi-heart-fill' : 'bi-heart' %> me-1"></i>
                  <%= likedByMe ? 'Curtido' : 'Curtir' %>
                  <span class="badge rounded-pill ms-1"><%= likeCount %></span>
                </button>
              </form>
            <% } else { %>
              <a href="/login" class="btn btn-outline-light">
                <i class="bi bi-heart me-1"></i>Curtir
                <span class="badge rounded-pill ms-1"><%= likeCount %></span>
              </a>
            <% } %>

            <a href="<%= project.linkPj %>" target="_blank" rel="noopener" class="btn btn-gradient">
              <i class="bi bi-box-arrow-up-right me-1"></i>Ver projeto ao vivo
            </a>
          </div>
        </div>
      </article>

      <!-- Comentários -->
      <section id="comentarios" class="glass p-4 p-md-5">
        <h2 class="h4 mb-4"><i class="bi bi-chat-left-text me-2 gradient-text"></i>Comentários (<%= comments.length %>)</h2>

        <% if (currentUser) { %>
          <form action="/projeto/<%= project.id %>/comment" method="post" class="mb-4">
            <textarea class="form-control mb-2" name="body" rows="3" maxlength="2000"
              placeholder="Escreva um comentário (suporta markdown)..." required></textarea>
            <button class="btn btn-gradient" type="submit"><i class="bi bi-send me-1"></i>Comentar</button>
          </form>
        <% } else { %>
          <div class="alert" style="background:var(--surface-2);border-color:var(--border);">
            <a href="/login" style="color:var(--accent-2);">Entre na sua conta</a> para curtir e comentar.
          </div>
        <% } %>

        <% if (comments.length === 0) { %>
          <p class="text-muted-2 mb-0">Seja o primeiro a comentar!</p>
        <% } else { %>
          <div class="d-flex flex-column gap-3">
            <% comments.forEach(c => { %>
              <div class="comment">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <div class="d-flex align-items-center gap-2">
                    <span class="comment-avatar"><%= c.userName.charAt(0).toUpperCase() %></span>
                    <strong><%= c.userName %></strong>
                    <small class="text-muted-2"><%= new Date(c.createdAt).toLocaleDateString('pt-BR') %></small>
                  </div>
                  <% if (currentUser && String(c.user) === String(currentUser.id)) { %>
                    <form action="/projeto/<%= project.id %>/comment/<%= c._id %>/delete" method="post" class="m-0"
                      data-confirm="Excluir seu comentário?" data-confirm-btn="Excluir">
                      <button class="btn btn-sm btn-link text-danger p-0" title="Excluir"><i class="bi bi-trash"></i></button>
                    </form>
                  <% } %>
                </div>
                <div class="markdown-body comment-body"><%- md(c.body) %></div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

    </div>
  </main>

  <footer class="text-center py-3 mt-auto">
    <small>&copy; <%= new Date().getFullYear() %> · CoddeX Developer</small>
  </footer>
</body>

</html>
