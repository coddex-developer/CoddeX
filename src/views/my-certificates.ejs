<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 1100px;">
  <!-- Cabeçalho Principal -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard/editPage" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar aos Ajustes
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Meus Certificados</h1>
      <p class="text-muted mb-0">Gerencie suas certificações e qualificações.</p>
    </div>
    <div>
      <a href="/admin/dashboard/editPage/my-certificates/add-certificate" class="btn btn-gradient px-4 py-2 shadow-glow" style="background: linear-gradient(135deg, var(--warning) 0%, #ff8a00 100%); box-shadow: 0 4px 20px rgba(255, 138, 0, 0.4);">
        <i class="bi bi-plus-lg me-2"></i>Novo Certificado
      </a>
    </div>
  </div>

  <div class="row g-4">
    <% if (certificates && certificates.length > 0) { %>
      <% certificates.forEach(function(certificate) { %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card h-100 border-0 glass-panel overflow-hidden" style="border-radius: var(--radius-lg); transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <!-- Imagem do Certificado -->
            <div class="position-relative" style="height: 220px; overflow: hidden; background: rgba(0,0,0,0.5);">
              <img src="<%= certificate.image %>" class="w-100 h-100" style="object-fit: contain; padding: 1rem; transition: transform 0.5s ease;" alt="<%= certificate.title %>" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
              <div class="position-absolute bottom-0 start-0 w-100 h-50" style="background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.9) 100%); pointer-events: none;"></div>
              <h5 class="position-absolute bottom-0 start-0 m-3 mb-2 text-white fw-bold"><%= certificate.title %></h5>
            </div>
            
            <!-- Ações -->
            <div class="card-footer bg-transparent border-0 d-flex gap-2 p-3" style="background: var(--surface-solid) !important;">
              <a href="/admin/dashboard/editPage/my-certificates/<%= certificate.id %>" class="btn btn-secondary flex-grow-1" style="border-radius: 8px;">
                <i class="bi bi-pencil-square me-1"></i>Editar
              </a>
              <form action="/admin/dashboard/editPage/my-certificates/<%= certificate.id %>" method="post"
                class="m-0 ajax-form" data-confirm="Excluir o certificado '<%= certificate.title %>'? Esta ação não pode ser desfeita."
                data-confirm-title="Excluir Certificado" data-confirm-btn="Excluir">
                <button class="btn btn-outline-danger px-3 h-100" style="border-radius: 8px;" type="submit" title="Excluir Certificado">
                  <i class="bi bi-trash3-fill"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-12">
        <div class="glass-panel p-5 text-center border-0" style="background: rgba(255, 138, 0, 0.05);">
          <i class="bi bi-award text-muted mb-3 d-block" style="font-size: 3rem; color: var(--warning) !important;"></i>
          <h5 class="text-white fw-bold">Nenhum Certificado Encontrado</h5>
          <p class="text-muted mb-4">Você ainda não adicionou nenhum certificado ao seu perfil.</p>
          <a href="/admin/dashboard/editPage/my-certificates/add-certificate" class="btn btn-outline-warning px-4 text-white">Adicionar o Primeiro Certificado</a>
        </div>
      </div>
    <% } %>    
  </div>
</div>

<style>
  .card.glass-panel:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.5), 0 0 15px rgba(255, 138, 0, 0.1) !important;
    border-color: rgba(255, 138, 0, 0.3) !important;
  }
</style>

<%- include('fragments/footer') %>