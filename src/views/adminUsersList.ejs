<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 1000px;">
  <!-- Cabeçalho -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar ao Painel
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Gestão de Usuários</h1>
      <p class="text-muted mb-0">Controle total das contas cadastradas na plataforma.</p>
    </div>
    <div class="d-flex gap-2">
      <div class="bg-surface border border-white-50 rounded-pill px-4 py-2 glass">
        <span class="text-muted small text-uppercase fw-bold me-2">Total:</span>
        <span class="fw-bold text-white"><%= users.length %></span>
      </div>
    </div>
  </div>

  <!-- Lista de Usuarios -->
  <div class="glass-panel border-0" style="overflow: visible !important;">
    <% if (users && users.length > 0) { %>
      <div class="table-responsive" style="overflow: visible !important;">
        <table class="table table-dark table-hover mb-0" style="background: transparent;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border-strong);">
              <th scope="col" class="py-3 px-4 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Usuário</th>
              <th scope="col" class="py-3 px-4 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">E-mail & Status</th>
              <th scope="col" class="py-3 px-4 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Situação</th>
              <th scope="col" class="py-3 px-4 text-end text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Ações Root</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr style="border-bottom: 1px solid var(--border);">
                <td class="py-3 px-4 align-middle">
                  <div class="d-flex align-items-center">
                    <% if (user.avatar) { %>
                      <img src="<%= user.avatar %>" alt="User" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover; border: 1px solid var(--accent-1);">
                    <% } else { %>
                      <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.2); color: var(--accent-2);">
                        <i class="bi bi-person-fill"></i>
                      </div>
                    <% } %>
                    <div>
                      <span class="d-block fw-bold text-white"><%= user.name %></span>
                      <small class="text-muted text-uppercase" style="font-size: 0.7rem;"><%= user.role || 'user' %></small>
                    </div>
                  </div>
                </td>
                <td class="py-3 px-4 align-middle">
                  <span class="d-block text-white"><%= user.email %></span>
                  <% if(user.emailVerified) { %>
                    <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-2 py-1 mt-1 border border-success border-opacity-50" style="font-size: 0.65rem;">Verificado</span>
                  <% } else { %>
                    <span class="badge bg-warning bg-opacity-25 text-warning rounded-pill px-2 py-1 mt-1 border border-warning border-opacity-50" style="font-size: 0.65rem;">Pendente</span>
                  <% } %>
                </td>
                <td class="py-3 px-4 align-middle">
                  <span id="status-<%= user._id %>" class="badge <%= user.isBlocked ? 'bg-danger text-danger' : 'bg-primary text-primary' %> bg-opacity-25 rounded-pill px-2 py-1 border <%= user.isBlocked ? 'border-danger' : 'border-primary' %> border-opacity-50" style="font-size: 0.65rem;">
                    <%= user.isBlocked ? 'Bloqueado' : 'Ativo' %>
                  </span>
                </td>
                <td class="py-3 px-4 align-middle text-end">
                  <div class="dropup d-inline">
                    <button class="btn btn-outline-light btn-sm rounded-pill flex" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                      ...<!-- <i class="bi bi-fire ms-1" style="font-size: 0.7rem;"></i> -->
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow position-absolute z-3" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
                      <li>
                        <button class="dropdown-item d-flex align-items-center py-2" 
                          data-id="<%= user._id %>" 
                          data-name="<%= user.name %>" 
                          data-email="<%= user.email %>" 
                          data-avatar="<%= user.avatar || '' %>" 
                          data-blocked="<%= user.isBlocked %>" 
                          onclick="showInteractions(this)">
                          <i class="bi bi-person-lines-fill text-info me-2"></i> Gerenciar Usuário
                        </button>
                      </li>
                      <li><hr class="dropdown-divider border-secondary"></li>
                      <li>
                        <form action="/admin/dashboard/users/<%= user._id %>/delete" method="post" class="m-0 ajax-form-delete"
                          data-confirm="Banir e excluir definitivamente o usuário '<%= user.name %>'? Esta ação não pode ser desfeita.">
                          <button class="dropdown-item d-flex align-items-center py-2 text-danger" type="submit">
                            <i class="bi bi-trash3-fill me-2"></i> Excluir Definitivamente
                          </button>
                        </form>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="p-5 text-center">
        <i class="bi bi-people text-muted mb-3" style="font-size: 3rem;"></i>
        <h5 class="text-white fw-bold">Nenhum Usuário Encontrado</h5>
        <p class="text-muted">Ainda não há clientes cadastrados na base de dados.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- Modal Interações e Perfil -->
<div class="modal fade" id="interactionsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title fw-bold text-white"><i class="bi bi-person-lines-fill text-info me-2"></i> Gerenciar Usuário</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4 text-center" id="intLoading">
        <div class="spinner-border text-primary" role="status"></div>
      </div>
      <div class="modal-body p-4 d-none" id="intContent">
        
        <!-- Perfil do Usuário -->
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary">
          <div id="modalUserAvatarWrapper" class="me-3">
            <img id="modalUserAvatar" src="" alt="User" class="rounded-circle d-none" style="width: 60px; height: 60px; object-fit: cover; border: 2px solid var(--accent-1);">
            <div id="modalUserAvatarFallback" class="rounded-circle d-flex align-items-center justify-content-center d-none" style="width: 60px; height: 60px; background: rgba(0, 240, 255, 0.1); border: 2px solid rgba(0, 240, 255, 0.2); color: var(--accent-2); font-size: 1.5rem;">
              <i class="bi bi-person-fill"></i>
            </div>
          </div>
          <div class="text-start">
            <h5 class="fw-bold text-white mb-0" id="modalUserName">Nome</h5>
            <small class="text-muted d-block" id="modalUserEmail">@email</small>
            <span id="modalUserStatus" class="badge mt-1" style="font-size: 0.65rem;"></span>
          </div>
        </div>

        <!-- Estatísticas -->
        <div class="row text-center g-2 mb-4">
          <div class="col-4">
            <div class="p-2 rounded" style="background: var(--surface-2); border: 1px solid var(--border);">
              <h5 class="fw-bold text-white mb-0" id="intComments">0</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Comentários</small>
            </div>
          </div>
          <div class="col-4">
            <div class="p-2 rounded" style="background: var(--surface-2); border: 1px solid var(--border);">
              <h5 class="fw-bold text-white mb-0" id="intLikes">0</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Curtidas</small>
            </div>
          </div>
          <div class="col-4">
            <div class="p-2 rounded" style="background: var(--surface-2); border: 1px solid var(--border);">
              <h5 class="fw-bold text-white mb-0" id="intTickets">0</h5>
              <small class="text-muted" style="font-size: 0.65rem;">Tickets</small>
            </div>
          </div>
        </div>

        <!-- Gráfico -->
        <div class="mb-4" style="height: 180px; position: relative;">
          <canvas id="interactionsChart"></canvas>
        </div>
        
        <!-- Ações do Usuário -->
        <div class="d-flex flex-column gap-2 mt-4 pt-3 border-top border-secondary">
          <button class="btn btn-outline-warning w-100 d-flex justify-content-center align-items-center" type="button" id="modalBtnChangePassword">
            <i class="bi bi-key me-2"></i> Alterar Senha
          </button>
          
          <form id="modalBlockForm" method="post" class="m-0 ajax-form-block w-100">
            <button class="btn btn-outline-danger w-100 d-flex justify-content-center align-items-center" type="submit" id="modalBtnBlock">
              <i class="bi bi-lock me-2" id="modalIconBlock"></i> <span id="modalTextBlock">Bloquear Conta</span>
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Modal Alterar Senha -->
<div class="modal fade" id="passwordModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title fw-bold text-white"><i class="bi bi-key text-warning me-2"></i> Nova Senha para <span id="passUserName"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="passwordForm">
        <div class="modal-body p-4">
          <input type="hidden" id="passUserId">
          <div class="mb-3">
            <label class="form-label text-muted small fw-bold">Nova Senha</label>
            <input type="text" class="form-control text-white" id="newPassword" name="newPassword" placeholder="Mínimo de 6 caracteres" style="background: var(--bg); border: 1px solid var(--border);" required minlength="6">
          </div>
        </div>
        <div class="modal-footer border-top border-secondary">
          <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold">Salvar Senha</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Excluir e Bloquear forms via AJAX com SweetAlert2
  document.querySelectorAll('.ajax-form-block, .ajax-form-delete').forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const msg = form.getAttribute('data-confirm');
      Swal.fire({
        title: 'Confirmação',
        text: msg,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Sim, confirmar',
        cancelButtonText: 'Cancelar',
        background: 'var(--surface-1)',
        color: 'var(--text)',
        confirmButtonColor: form.classList.contains('ajax-form-delete') ? 'var(--danger)' : 'var(--primary)'
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(form.action, {
            method: form.method,
            headers: { 'Accept': 'application/json' }
          }).then(res => res.json()).then(data => {
            if (data.success) {
              Swal.fire({
                icon: 'success', title: 'Sucesso', text: data.message, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, background: 'var(--surface-1)', color: 'var(--text)'
              });
              if (data.redirect) {
                setTimeout(() => window.location.href = data.redirect, 1000);
              } else if (form.classList.contains('ajax-form-block')) {
                // Atualiza a linha localmente
                setTimeout(() => window.location.reload(), 1000); // Reload pra garantir atualização correta das classes
              }
            } else {
              Swal.fire({ icon: 'error', title: 'Erro', text: data.error, background: 'var(--surface-1)', color: 'var(--text)' });
            }
          });
        }
      });
    });
  });

  let intChartInstance = null;

  function showInteractions(btn) {
    const intModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('interactionsModal'));
    const id = btn.getAttribute('data-id');
    const name = btn.getAttribute('data-name');
    const email = btn.getAttribute('data-email');
    const avatar = btn.getAttribute('data-avatar');
    const isBlocked = btn.getAttribute('data-blocked') === 'true';

    // Set Profile Info
    document.getElementById('modalUserName').innerText = name;
    document.getElementById('modalUserEmail').innerText = email;
    
    const avatarImg = document.getElementById('modalUserAvatar');
    const avatarFallback = document.getElementById('modalUserAvatarFallback');
    if (avatar) {
      avatarImg.src = avatar;
      avatarImg.classList.remove('d-none');
      avatarFallback.classList.add('d-none');
    } else {
      avatarImg.classList.add('d-none');
      avatarFallback.classList.remove('d-none');
    }

    // Set Status
    const statusBadge = document.getElementById('modalUserStatus');
    if (isBlocked) {
      statusBadge.className = 'badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-50 mt-1';
      statusBadge.innerText = 'Bloqueado';
    } else {
      statusBadge.className = 'badge bg-primary bg-opacity-25 text-primary border border-primary border-opacity-50 mt-1';
      statusBadge.innerText = 'Ativo';
    }

    // Configure Actions
    document.getElementById('modalBtnChangePassword').onclick = () => {
      intModal.hide();
      showPasswordModal(id, name);
    };

    const blockForm = document.getElementById('modalBlockForm');
    blockForm.action = `/admin/dashboard/users/${id}/block`;
    const actionText = isBlocked ? 'desbloquear' : 'bloquear';
    blockForm.setAttribute('data-confirm', `Tem certeza que deseja ${actionText} o acesso de '${name}'?`);
    
    document.getElementById('modalIconBlock').className = isBlocked ? 'bi bi-unlock me-2' : 'bi bi-lock me-2';
    document.getElementById('modalTextBlock').innerText = isBlocked ? 'Desbloquear Conta' : 'Bloquear Conta';
    document.getElementById('modalBtnBlock').className = isBlocked ? 'btn btn-outline-success w-100 d-flex justify-content-center align-items-center' : 'btn btn-outline-danger w-100 d-flex justify-content-center align-items-center';

    // Show Loading
    document.getElementById('intLoading').classList.remove('d-none');
    document.getElementById('intContent').classList.add('d-none');
    intModal.show();

    fetch(`/admin/dashboard/users/${id}/interactions`, { headers: { 'Accept': 'application/json' } })
      .then(res => res.json())
      .then(data => {
        if(data.success) {
          const comments = data.stats.comments || 0;
          const likes = data.stats.likes || 0;
          const tickets = data.stats.tickets || 0;
          
          document.getElementById('intComments').innerText = comments;
          document.getElementById('intLikes').innerText = likes;
          document.getElementById('intTickets').innerText = tickets;
          
          renderChart(comments, likes, tickets);

          document.getElementById('intLoading').classList.add('d-none');
          document.getElementById('intContent').classList.remove('d-none');
        }
      });
  }

  function renderChart(comments, likes, tickets) {
    const ctx = document.getElementById('interactionsChart').getContext('2d');
    
    if (intChartInstance) {
      intChartInstance.destroy();
    }

    intChartInstance = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Comentários', 'Curtidas', 'Tickets'],
        datasets: [{
          data: [comments, likes, tickets],
          backgroundColor: [
            'rgba(0, 240, 255, 0.7)',
            'rgba(255, 0, 127, 0.7)',
            'rgba(255, 193, 7, 0.7)'
          ],
          borderColor: [
            'rgba(0, 240, 255, 1)',
            'rgba(255, 0, 127, 1)',
            'rgba(255, 193, 7, 1)'
          ],
          borderWidth: 1,
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'right',
            labels: { color: '#8b949e', font: { size: 11 } }
          }
        },
        cutout: '65%'
      }
    });
  }

  function getPassModal() {
    return bootstrap.Modal.getOrCreateInstance(document.getElementById('passwordModal'));
  }

  function showPasswordModal(id, name) {
    document.getElementById('passUserName').innerText = name;
    document.getElementById('passUserId').value = id;
    document.getElementById('newPassword').value = '';
    getPassModal().show();
  }

  document.getElementById('passwordForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const id = document.getElementById('passUserId').value;
    const newPassword = document.getElementById('newPassword').value;
    
    fetch(`/admin/dashboard/users/${id}/password`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ newPassword })
    }).then(res => res.json()).then(data => {
      if(data.success) {
        getPassModal().hide();
        Swal.fire({ icon: 'success', title: 'Sucesso', text: data.message, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, background: 'var(--surface-1)', color: 'var(--text)' });
      } else {
        Swal.fire({ icon: 'error', title: 'Erro', text: data.error, background: 'var(--surface-1)', color: 'var(--text)' });
      }
    });
  });
</script>

<%- include('fragments/footer') %>
