<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 760px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Perfil & Configurações</h1>
    <a href="/admin/dashboard" class="btn btn-outline-light btn-sm"><i class="bi bi-house-fill me-1"></i>Início</a>
  </div>

  <!-- 1. Credenciais do administrador -->
  <form class="glass p-4 mb-4" action="/admin/dashboard/adminProfile" enctype="multipart/form-data" method="post"
    data-confirm="Salvar novas credenciais? Você será deslogado." data-confirm-title="Salvar credenciais" data-confirm-btn="Salvar">
    <h2 class="h5 mb-3"><i class="bi bi-person-badge-fill me-2 gradient-text"></i>Credenciais</h2>

    <label class="upload-drop d-flex flex-column align-items-center justify-content-center text-center mb-3" for="file">
      <i class="bi bi-cloud-arrow-up-fill fs-1 mb-1 gradient-text"></i>
      <span class="text-muted-2">Enviar nova logo</span>
      <input type="file" id="file" name="logo" accept="image/*" hidden data-preview="#logoPreview">
    </label>
    <img id="logoPreview" class="img-preview mb-3" style="display:none;" alt="Pré-visualização da logo">

    <div class="mb-3">
      <label for="username" class="form-label"><i class="bi bi-person me-1"></i>Nome de usuário</label>
      <input type="text" class="form-control" id="username" name="username" value="<%= adminUser.userAdmin %>" required>
    </div>
    <div class="mb-3">
      <label for="password" class="form-label"><i class="bi bi-lock me-1"></i>Nova senha</label>
      <div class="password-wrap" style="position: relative;">
        <input type="password" class="form-control" id="password" name="password" placeholder="Digite a nova senha" required>
        <button type="button" id="buttonView" class="toggle-pass" aria-label="Mostrar senha"
          style="position:absolute; top:50%; right:.5rem; transform:translateY(-50%); background:transparent; border:none; color:var(--text-muted); width:2.2rem; height:2.2rem; border-radius:8px; cursor:pointer;">
          <i class="bi bi-eye"></i>
        </button>
      </div>
    </div>
    <button class="btn btn-gradient" type="submit"><i class="bi bi-save me-2"></i>Salvar credenciais</button>
  </form>

  <!-- 2. Redes sociais e contato -->
  <form id="social" class="glass p-4 mb-4" action="/admin/dashboard/profile/social" method="post">
    <h2 class="h5 mb-3"><i class="bi bi-share-fill me-2 gradient-text"></i>Redes sociais e contato</h2>
    <p class="text-muted-2 small mb-3">Os links preenchidos aparecem no rodapé do site.</p>
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-github me-1"></i>GitHub</label>
        <input type="url" class="form-control" name="github" value="<%= site.social.github %>" placeholder="https://github.com/...">
      </div>
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-linkedin me-1"></i>LinkedIn</label>
        <input type="url" class="form-control" name="linkedin" value="<%= site.social.linkedin %>" placeholder="https://linkedin.com/in/...">
      </div>
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-instagram me-1"></i>Instagram</label>
        <input type="url" class="form-control" name="instagram" value="<%= site.social.instagram %>" placeholder="https://instagram.com/...">
      </div>
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-whatsapp me-1"></i>WhatsApp</label>
        <input type="url" class="form-control" name="whatsapp" value="<%= site.social.whatsapp %>" placeholder="https://wa.me/55...">
      </div>
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-envelope me-1"></i>E-mail de contato</label>
        <input type="email" class="form-control" name="contactEmail" value="<%= site.contactEmail %>" placeholder="voce@email.com">
      </div>
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-telephone me-1"></i>Telefone</label>
        <input type="text" class="form-control" name="contactPhone" value="<%= site.contactPhone %>" placeholder="(DDD) 9 9999-9999">
      </div>
    </div>
    <button class="btn btn-gradient mt-3" type="submit"><i class="bi bi-save me-2"></i>Salvar redes sociais</button>
  </form>

  <!-- 3. E-mail (SMTP) -->
  <div id="mail" class="glass p-4 mb-4">
   <form action="/admin/dashboard/profile/mail" method="post">
    <h2 class="h5 mb-3"><i class="bi bi-envelope-at-fill me-2 gradient-text"></i>E-mail (SMTP)</h2>
    <p class="text-muted-2 small mb-3">Para Gmail, deixe o host vazio e use uma <strong>senha de app</strong> (não a senha normal).</p>
    <div class="row g-3">
      <div class="col-md-8">
        <label class="form-label">Host <span class="text-muted-2">(vazio = Gmail)</span></label>
        <input type="text" class="form-control" name="mailHost" value="<%= site.mail.host %>" placeholder="smtp.seuprovedor.com">
      </div>
      <div class="col-md-4">
        <label class="form-label">Porta</label>
        <input type="text" class="form-control" name="mailPort" value="<%= site.mail.port %>" placeholder="587">
      </div>
      <div class="col-md-6">
        <label class="form-label">Usuário (e-mail)</label>
        <input type="text" class="form-control" name="mailUser" value="<%= site.mail.user %>" placeholder="voce@gmail.com">
      </div>
      <div class="col-md-6">
        <label class="form-label">Senha <% if (site.mail.pass) { %><span class="text-muted-2">(salva — deixe em branco para manter)</span><% } %></label>
        <input type="password" class="form-control" name="mailPass" placeholder="<%= site.mail.pass ? '••••••••' : 'senha de app' %>">
      </div>
      <div class="col-md-8">
        <label class="form-label">Remetente (From)</label>
        <input type="text" class="form-control" name="mailFrom" value="<%= site.mail.from %>" placeholder="CoddeX <no-reply@coddex.store>">
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="mailSecure" name="mailSecure" <%= site.mail.secure ? 'checked' : '' %>>
          <label class="form-check-label" for="mailSecure">SSL/TLS</label>
        </div>
      </div>
    </div>
    <hr class="my-3" style="border-color:var(--border);">
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="requireVerification" name="requireVerification"
        <%= (site.requireEmailVerification !== false) ? 'checked' : '' %>>
      <label class="form-check-label" for="requireVerification">
        Exigir verificação de e-mail no cadastro
        <span class="text-muted-2 d-block small">Se desligado, novas contas entram sem precisar confirmar o e-mail (não requer SMTP).</span>
      </label>
    </div>
    <button class="btn btn-gradient mt-3" type="submit"><i class="bi bi-save me-2"></i>Salvar e-mail</button>
   </form>
   <form action="/admin/dashboard/profile/mail/test" method="post" class="mt-2 d-inline">
     <button class="btn btn-outline-light" type="submit"><i class="bi bi-send-check me-2"></i>Testar conexão</button>
   </form>
   <p class="text-muted-2 small mt-2 mb-0">Salve primeiro, depois teste. O teste valida as credenciais e envia um e-mail de teste.</p>
  </div>

  <!-- 4. Cloudinary -->
  <form id="cloudinary" class="glass p-4 mb-4" action="/admin/dashboard/profile/cloudinary" method="post">
    <h2 class="h5 mb-3"><i class="bi bi-cloud-fill me-2 gradient-text"></i>Cloudinary (upload de imagens)</h2>
    <p class="text-muted-2 small mb-3">Credenciais do painel Cloudinary (Dashboard → Account Details).</p>
    <div class="row g-3">
      <div class="col-md-4">
        <label class="form-label">Cloud name</label>
        <input type="text" class="form-control" name="cloudName" value="<%= site.cloudinary.cloudName %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">API Key</label>
        <input type="text" class="form-control" name="cloudApiKey" value="<%= site.cloudinary.apiKey %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">API Secret <% if (site.cloudinary.apiSecret) { %><span class="text-muted-2">(salvo)</span><% } %></label>
        <input type="password" class="form-control" name="cloudApiSecret" placeholder="<%= site.cloudinary.apiSecret ? '••••••••' : 'sua api secret' %>">
      </div>
    </div>
    <button class="btn btn-gradient mt-3" type="submit"><i class="bi bi-save me-2"></i>Salvar Cloudinary</button>
  </form>
</div>

<script>
  const password = document.getElementById("password");
  const buttonView = document.getElementById("buttonView");
  buttonView.addEventListener("click", () => {
    const show = password.type === "password";
    password.type = show ? "text" : "password";
    buttonView.innerHTML = show ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
  });
</script>

<%- include('fragments/footer') %>
