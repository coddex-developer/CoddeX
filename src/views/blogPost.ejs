<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: post.title + ' · ' + site.title, pageDescription: post.title }) %>
  <link rel="stylesheet" href="/styles/style.css">
</head>

<body class="d-flex flex-column min-vh-100">
  <nav class="navbar sticky-top" data-bs-theme="dark">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 38px;">
        <span class="fw-bold gradient-text d-none d-sm-inline"><%= site.title %></span>
      </a>
      <a href="/blog" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i>Blog</a>
    </div>
  </nav>

  <main class="flex-grow-1">
    <article class="container py-5" style="max-width: 760px;">
      <% if (post.coverImage) { %>
        <img src="<%= post.coverImage %>" alt="<%= post.title %>" class="w-100 mb-4" style="max-height:380px;object-fit:cover;border-radius:var(--radius);">
      <% } %>
      <h1 class="section-title gradient-text mb-2"><%= post.title %></h1>
      <p class="text-muted-2 mb-4"><i class="bi bi-calendar3 me-1"></i><%= new Date(post.createdAt).toLocaleDateString('pt-BR') %></p>
      <div class="markdown-body article-body"><%- md(post.body) %></div>
    </article>
  </main>

  <footer class="text-center py-3 mt-auto"><small>&copy; <%= new Date().getFullYear() %> · <%= site.title %></small></footer>
</body>

</html>
