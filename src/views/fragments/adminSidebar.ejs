<!-- Botão Mobile para abrir o Sidebar -->
<div class="d-md-none p-3 d-flex align-items-center justify-content-between mb-3 rounded shadow-sm" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
  <div class="d-flex align-items-center gap-2">
    <img src="/assets/admin1.png" alt="Admin" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 1px solid var(--accent-1);">
    <div>
      <h6 class="mb-0 text-white fw-bold">Administrador</h6>
      <small style="color: var(--text-muted); font-size: 0.75rem;">Painel de Controle</small>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    <!-- Notificações Bell -->
    <button class="btn p-0 position-relative border-0 bg-transparent text-white" type="button" data-bs-toggle="modal" data-bs-target="#notificationsModal" id="mobileNotifBtn">
      <i class="bi bi-bell fs-5"></i>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="mobileNotifBadge" style="font-size: 0.6rem; padding: 0.25em 0.4em; transform: translate(-40%, 10%) !important;">
        0
      </span>
    </button>
    <button class="btn btn-outline-light btn-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
      <i class="bi bi-list fs-5"></i>
    </button>
  </div>
</div>

<!-- Sidebar Desktop / Offcanvas Mobile -->
<div class="offcanvas-md offcanvas-start" tabindex="-1" id="sidebarOffcanvas" style="background: var(--surface-1); border-right: 1px solid var(--border-strong);">
  <div class="offcanvas-header border-bottom border-secondary d-md-none">
    <h5 class="offcanvas-title fw-bold d-flex align-items-center" style="color: var(--text);">
      <img src="/assets/admin1.png" alt="Admin" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover; border: 1px solid var(--accent-1);">
      Menu
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#sidebarOffcanvas" aria-label="Close"></button>
  </div>
  
  <div class="offcanvas-body d-flex flex-column p-0 h-100">
    <div class="p-4 text-center d-none d-md-block border-bottom" style="border-color: var(--border-strong) !important;">
      <div class="position-relative d-inline-block mb-3">
        <img src="/assets/admin1.png" alt="Admin" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover; border: 2px solid var(--accent-1);">
        <a href="/admin/dashboard/adminProfile" class="position-absolute bottom-0 end-0 bg-gradient rounded-circle d-flex align-items-center justify-content-center text-white text-decoration-none shadow" style="width: 28px; height: 28px; border: 2px solid var(--surface-1); cursor: pointer;">
          <i class="bi bi-pencil-fill" style="font-size: 0.75rem;"></i>
        </a>
      </div>
      <h5 class="fw-bold mb-0" style="color: var(--text);">Administrador</h5>
      <span class="badge mt-2" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-strong); color: var(--text-muted);">Painel de Controle</span>
    </div>

    <div class="p-3 flex-grow-1">
      <% const activePath = typeof currentPath !== 'undefined' ? currentPath : '/admin/dashboard'; %>
      <ul class="nav flex-column gap-2">
        <li class="nav-item">
          <a href="/admin/dashboard" class="nav-link text-white rounded p-3 d-flex align-items-center justify-content-between gap-3 <%= activePath === '/admin/dashboard' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <div><i class="bi bi-speedometer2 fs-5 me-2"></i> Dashboard</div>
          </a>
        </li>
        <li class="nav-item">
          <a href="/admin/dashboard/unread" class="nav-link text-white rounded p-3 d-flex align-items-center justify-content-between gap-3 <%= activePath === '/admin/dashboard/unread' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <div><i class="bi bi-envelope-open fs-5 me-2"></i> Mensagens</div>
            <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
              <span class="badge bg-danger rounded-pill"><%= unreadCount %></span>
            <% } %>
          </a>
        </li>
        <li class="nav-item">
          <a href="/admin/dashboard/tickets" class="nav-link text-white rounded p-3 d-flex align-items-center justify-content-between gap-3 <%= activePath === '/admin/dashboard/tickets' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <div><i class="bi bi-chat-dots fs-5 me-2"></i> Conversas</div>
          </a>
        </li>
        <li class="nav-item">
          <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="nav-link text-white rounded p-3 d-flex align-items-center justify-content-between gap-3 <%= activePath.includes('/CreateProjects/allProjects') ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <div><i class="bi bi-window-stack fs-5 me-2"></i> Projetos</div>
            <% if (typeof projectCount !== 'undefined') { %>
              <span class="badge bg-secondary rounded-pill"><%= projectCount %></span>
            <% } %>
          </a>
        </li>
        <li class="nav-item">
          <a href="/admin/dashboard/users" class="nav-link text-white rounded p-3 d-flex align-items-center justify-content-between gap-3 <%= activePath === '/admin/dashboard/users' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <div><i class="bi bi-people-fill fs-5 me-2"></i> Usuários</div>
          </a>
        </li>
        <li class="nav-item">
          <a href="/admin/dashboard/editPage" class="nav-link text-white rounded p-3 d-flex align-items-center gap-3 <%= activePath === '/admin/dashboard/editPage' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <div><i class="bi bi-gear fs-5 me-2"></i> Ajustes do Site</div>
          </a>
        </li>
      </ul>
    </div>
    
    <div class="p-3 mt-auto border-top" style="border-color: var(--border) !important;">
      <a href="/" class="btn btn-outline-light w-100 mb-2" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i>Ver Site</a>
      <a href="/admin/dashboard/logout" class="btn btn-danger w-100"><i class="bi bi-box-arrow-right me-2"></i>Sair</a>
    </div>
  </div>
</div>

<style>
  .hover-bg:hover { background: rgba(255,255,255,0.05); }
  @media (min-width: 768px) {
    #sidebarOffcanvas { position: sticky; top: 20px; height: calc(100vh - 40px); border-radius: var(--radius); }
  }
</style>
