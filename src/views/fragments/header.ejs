<!DOCTYPE html>
<html lang="pt-br" data-theme="dark">

<head>
  <%- include('head', { pageTitle: typeof pageTitle !== 'undefined' ? pageTitle : 'Admin · CoddeX', pageDescription: 'Painel de Gerenciamento' }) %>
  <link rel="stylesheet" href="/styles/dashboard.css" />
  <style>
    /* Admin Sidebar Layout Styles */
    body { background-color: var(--bg); }
    .sidebar { width: 260px; min-height: 100vh; position: sticky; top: 0; z-index: 1040; transition: transform 0.3s ease; }
    .sidebar .nav-link { color: var(--text-muted); font-weight: 500; border-radius: 8px; margin-bottom: 4px; padding: 10px 16px; }
    .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: var(--surface-2); color: var(--accent-1); }
    .sidebar .nav-link i { font-size: 1.1rem; width: 24px; text-align: center; display: inline-block; }
    .main-wrapper { min-width: 0; }
    .topbar { height: 60px; z-index: 1030; }
    @media (max-width: 991.98px) {
      .sidebar { position: fixed; transform: translateX(-100%); }
      .sidebar.show { transform: translateX(0); }
      .sidebar-backdrop { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1035; display: none; }
      .sidebar-backdrop.show { display: block; }
    }
  </style>
</head>

<body class="d-flex min-vh-100">

  <!-- Mobile Sidebar Backdrop -->
  <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="document.getElementById('sidebar').classList.remove('show'); this.classList.remove('show');"></div>

  <!-- Sidebar -->
  <aside class="sidebar bg-surface border-end d-flex flex-column py-3 px-3 shadow-sm" id="sidebar">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
      <a href="/admin/dashboard" class="d-flex align-items-center text-decoration-none">
        <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 36px;" class="me-2">
        <span class="fs-5 fw-bold gradient-text">CoddeX</span>
      </a>
      <button class="btn btn-sm btn-outline-secondary d-lg-none border-0" onclick="document.getElementById('sidebar').classList.remove('show'); document.getElementById('sidebarBackdrop').classList.remove('show');">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <ul class="nav flex-column mb-auto">
      <li class="nav-item">
        <a href="/admin/dashboard" class="nav-link">
          <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/dashboard/unread" class="nav-link d-flex align-items-center justify-content-between">
          <div><i class="bi bi-envelope me-2"></i> Mensagens</div>
          <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
            <span class="badge bg-danger rounded-pill"><%= unreadCount %></span>
          <% } %>
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/dashboard/tickets" class="nav-link notif-bell d-flex align-items-center justify-content-between">
          <div><i class="bi bi-chat-dots me-2"></i> Conversas</div>
          <span id="notifBadge" class="badge bg-danger rounded-pill" style="display:none;"></span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/dashboard/editPage/CreateProjects/allProjects" class="nav-link d-flex align-items-center justify-content-between">
          <div><i class="bi bi-window-stack me-2"></i> Projetos</div>
          <% if (typeof projectCount !== 'undefined') { %>
            <span class="badge bg-secondary rounded-pill"><%= projectCount %></span>
          <% } %>
        </a>
      </li>

      <li class="nav-item">
        <a href="/admin/dashboard/users" class="nav-link">
          <i class="bi bi-people-fill me-2"></i> Usuários
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/dashboard/editPage" class="nav-link">
          <i class="bi bi-gear me-2"></i> Ajustes do Site
        </a>
      </li>
    </ul>

    <hr class="border-secondary opacity-25">
    
    <div class="px-2">
      <a href="/admin/dashboard/adminProfile" class="d-flex align-items-center text-decoration-none nav-link p-0 bg-transparent">
        <div class="account-avatar me-2" style="width: 32px; height: 32px; font-size: 1rem;"><i class="bi bi-person"></i></div>
        <div class="d-flex flex-column" style="line-height: 1.2;">
          <strong class="text-text" style="font-size: 0.9rem;">Administrador</strong>
          <small class="text-muted" style="font-size: 0.8rem;">Ver perfil</small>
        </div>
      </a>
    </div>
  </aside>

  <!-- Main Content Wrapper -->
  <div class="flex-grow-1 d-flex flex-column main-wrapper">
    <!-- Topbar -->
    <header class="topbar bg-surface border-bottom d-flex align-items-center justify-content-between px-3 px-md-4 shadow-sm position-sticky top-0">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-outline-secondary border-0 d-lg-none" onclick="document.getElementById('sidebar').classList.add('show'); document.getElementById('sidebarBackdrop').classList.add('show');">
          <i class="bi bi-list fs-4"></i>
        </button>
        <span class="fw-bold text-muted d-none d-sm-block">Painel de Controle</span>
      </div>
      
      <div class="d-flex align-items-center gap-3">
        <!-- Notificações Bell -->
        <button class="btn p-0 position-relative border-0 bg-transparent text-white me-1" type="button" data-bs-toggle="modal" data-bs-target="#notificationsModal" id="adminNotifBtn">
          <i class="bi bi-bell fs-5"></i>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="mobileNotifBadge" style="font-size: 0.6rem; padding: 0.25em 0.4em; transform: translate(-40%, 10%) !important;">
            0
          </span>
        </button>

        <a href="/" class="btn btn-outline-primary btn-sm d-none d-sm-inline-block" target="_blank">
          <i class="bi bi-box-arrow-up-right me-1"></i>Ver Site
        </a>
        <a href="/admin/dashboard/logout" class="btn btn-danger btn-sm" title="Sair">
          <i class="bi bi-box-arrow-right"></i><span class="d-none d-sm-inline ms-1">Sair</span>
        </a>
      </div>
    </header>

    <!-- Script to highlight active sidebar link -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('.sidebar .nav-link');
        
        navLinks.forEach(link => {
          const linkPath = link.getAttribute('href');
          // Match exact path, or if current path starts with link path (and link path is not just /admin/dashboard)
          if (currentPath === linkPath || (linkPath !== '/admin/dashboard' && currentPath.startsWith(linkPath))) {
            link.classList.add('active');
            link.style.backgroundColor = 'var(--surface-2)';
            link.style.color = 'var(--accent-1)';
          }
        });
      });
    </script>

    <!-- Main Content Area -->
    <main class="flex-grow-1 p-3 p-md-4 overflow-auto">
