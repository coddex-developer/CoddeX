<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('head', { pageTitle: 'Admin · CoddeX', pageDescription: 'Painel de Gerenciamento' }) %>
  <link rel="stylesheet" href="/styles/dashboard.css" />
</head>

<body class="d-flex flex-column min-vh-100">
  <header>
    <nav class="navbar navbar-expand-lg sticky-top" data-bs-theme="dark">
      <div class="container">
        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center gap-2" href="/admin/dashboard">
          <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 40px;">
          <span class="fw-bold gradient-text d-none d-sm-inline">CoddeX</span>
        </a>

        <div class="d-flex align-items-center gap-2">
          <a href="/" class="btn btn-outline-light btn-sm" target="_blank" title="Ver site">
            <i class="bi bi-box-arrow-up-right"></i>
          </a>
          <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
        </div>

        <!-- Itens do menu -->
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
            <li class="nav-item">
              <a class="nav-link position-relative" href="/admin/dashboard/unread">
                <i class="bi bi-envelope-fill me-1"></i> Mensagens
                <% if (unreadCount > 0) { %>
                  <span class="badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle"><%= unreadCount %></span>
                <% } %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link notif-bell" href="/admin/dashboard/tickets">
                <i class="bi bi-chat-dots-fill me-1"></i> Conversas
                <span id="notifBadge" class="badge rounded-pill" style="display:none;"></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/dashboard/editPage/CreateProjects/allProjects">
                <i class="bi bi-window-stack me-1"></i> Projetos
                <span class="badge rounded-pill ms-1"><%= projectCount %></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/dashboard/blog">
                <i class="bi bi-journal-text me-1"></i> Blog
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/dashboard/editPage">
                <i class="bi bi-gear-fill me-1"></i> Configurar site
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/dashboard/adminProfile">
                <i class="bi bi-person-circle me-1"></i> Perfil
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-danger" href="/admin/dashboard/logout">
                <i class="bi bi-box-arrow-right me-1"></i> Sair
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="flex-grow-1">
