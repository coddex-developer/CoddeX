<!-- Botão Mobile para abrir o Sidebar -->
<div class="d-md-none p-3 d-flex align-items-center justify-content-between mb-3 rounded" style="background: var(--surface-1); border: 1px solid var(--border-strong);">
  <div class="d-flex align-items-center gap-2">
    <% if (user.avatar) { %>
      <img src="<%= user.avatar %>" alt="<%= user.name %>" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
    <% } else { %>
      <div class="account-avatar" style="width: 40px; height: 40px; font-size: 1.2rem; background: var(--gradient); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><%= user.name.charAt(0).toUpperCase() %></div>
    <% } %>
    <div>
      <h6 class="mb-0 text-white fw-bold"><%= user.name %></h6>
      <small style="color: var(--text-muted); font-size: 0.75rem;">@<%= user.username || 'user' %></small>
    </div>
  </div>
  <div class="d-flex align-items-center gap-3">
    <button class="btn p-0 position-relative border-0 bg-transparent text-white" type="button" data-bs-toggle="modal" data-bs-target="#notificationsModal" id="mobileNotifBtn">
      <i class="bi bi-bell fs-5"></i>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="mobileNotifBadge" style="font-size: 0.6rem; padding: 0.25em 0.4em; transform: translate(-40%, 10%) !important;">
        0
      </span>
    </button>
    <button class="btn btn-outline-light btn-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
      <i class="bi bi-list fs-5"></i>
    </button>
  </div>
</div>

<!-- Sidebar Desktop / Offcanvas Mobile -->
<div class="offcanvas-md offcanvas-start" tabindex="-1" id="sidebarOffcanvas" style="background: var(--surface-1); border-right: 1px solid var(--border-strong);">
  <div class="offcanvas-header border-bottom border-secondary d-md-none">
    <h5 class="offcanvas-title fw-bold d-flex align-items-center" style="color: var(--text);">
      <% if (user.avatar) { %>
        <img src="<%= user.avatar %>" alt="<%= user.name %>" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover; border: 1px solid var(--accent-1);">
      <% } else { %>
        <div class="rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 1rem; background: var(--gradient); color: #fff;"><%= user.name.charAt(0).toUpperCase() %></div>
      <% } %>
      Menu
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#sidebarOffcanvas" aria-label="Close"></button>
  </div>
  
  <div class="offcanvas-body d-flex flex-column p-0 h-100">
    <div class="p-4 text-center d-none d-md-block border-bottom" style="border-color: var(--border-strong) !important;">
      <div class="position-relative d-inline-block mb-3">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.name %>" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover; border: 2px solid var(--accent-1);">
        <% } else { %>
          <div class="account-avatar mx-auto" style="width: 80px; height: 80px; font-size: 2rem; background: var(--gradient); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><%= user.name.charAt(0).toUpperCase() %></div>
        <% } %>
        <a href="/account/settings" class="position-absolute bottom-0 end-0 bg-gradient rounded-circle d-flex align-items-center justify-content-center text-white text-decoration-none shadow" style="width: 28px; height: 28px; border: 2px solid var(--surface-1); cursor: pointer;">
          <i class="bi bi-pencil-fill" style="font-size: 0.75rem;"></i>
        </a>
      </div>
      <h5 class="fw-bold mb-0" style="color: var(--text);"><%= user.name %></h5>
      <span class="badge mt-2" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-strong); color: var(--text-muted);">@<%= user.username || 'user' %></span>
    </div>

    <div class="p-3 flex-grow-1" style="overflow-y: auto;">
      <ul class="nav flex-column gap-2">
        <li class="nav-item">
          <a href="/account" class="nav-link text-white rounded p-3 d-flex align-items-center gap-3 <%= currentPath === '/account' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <i class="bi bi-house-door fs-5"></i> Início
          </a>
        </li>
        <li class="nav-item">
          <a href="/account/tickets" class="nav-link text-white rounded p-3 d-flex align-items-center gap-3 <%= currentPath === '/account/tickets' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <i class="bi bi-chat-dots fs-5"></i> Conversas
          </a>
        </li>
        <li class="nav-item">
          <a href="/account/settings" class="nav-link text-white rounded p-3 d-flex align-items-center gap-3 <%= currentPath === '/account/settings' ? 'active bg-gradient text-white fw-bold' : 'hover-bg' %>" style="transition: all 0.2s;">
            <i class="bi bi-gear fs-5"></i> Configurações
          </a>
        </li>
      </ul>
    </div>
    
    <div class="p-3 mt-auto border-top" style="border-color: var(--border) !important;">
      <a href="/" class="btn btn-outline-light w-100 mb-2"><i class="bi bi-arrow-left me-2"></i>Voltar ao Site</a>
      <a href="/logout" class="btn btn-danger w-100"><i class="bi bi-box-arrow-right me-2"></i>Sair</a>
    </div>
  </div>
</div>

<style>
  .hover-bg:hover { background: rgba(255,255,255,0.05); }
  @media (min-width: 768px) {
    #sidebarOffcanvas { position: sticky; top: 20px; height: calc(100vh - 40px); border-radius: var(--radius); }
  }
</style>

<!-- Inclusão do Modal de Notificações -->
<%- include('notificationsModal') %>
