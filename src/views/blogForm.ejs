<%- include('fragments/header') %>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<% const editing = Boolean(post); %>
<div class="container py-5" style="max-width: 760px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><%= editing ? 'Editar artigo' : 'Novo artigo' %></h1>
    <a href="/admin/dashboard/blog" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i>Voltar</a>
  </div>

  <form class="ajax-form glass p-4" method="post" enctype="multipart/form-data"
    action="<%= editing ? '/admin/dashboard/blog/' + post._id + '/update' : '/admin/dashboard/blog' %>">

    <div class="mb-3">
      <label for="title" class="form-label">Título</label>
      <input type="text" class="form-control" id="title" name="title" value="<%= editing ? post.title : '' %>" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Imagem de capa</label>
      <label class="upload-drop d-flex flex-column align-items-center justify-content-center text-center" for="imageFile">
        <i class="bi bi-cloud-arrow-up-fill fs-2 gradient-text"></i>
        <span class="text-muted-2"><%= editing ? 'Clique para trocar a capa' : 'Clique para enviar uma capa' %></span>
        <input type="file" id="imageFile" name="imageFile" accept="image/*" hidden data-preview="#coverPreview">
      </label>
      <img id="coverPreview" class="img-preview mt-2" <%= editing && post.coverImage ? '' : 'style="display:none;"' %>
        src="<%= editing && post.coverImage ? post.coverImage : '' %>" alt="Pré-visualização">
      <div class="upload-divider">— ou cole uma URL —</div>
      <input type="text" class="form-control" name="coverUrl" placeholder="https://exemplo.com/capa.jpg"
        value="<%= editing ? post.coverImage : '' %>">
    </div>

    <div class="mb-3">
      <label class="form-label">Conteúdo</label>
      <div id="editor-container" class="bg-surface text-text" style="height: 300px; border-radius: 0 0 8px 8px;"><%- editing ? md(post.body) : '' %></div>
      <textarea id="body" name="body" style="display:none;"></textarea>
    </div>

    <div class="form-check form-switch mb-4 mt-4">
      <input class="form-check-input" type="checkbox" role="switch" id="published" name="published"
        <%= editing && post.published ? 'checked' : '' %>>
      <label class="form-check-label" for="published">Publicar (visível no site)</label>
    </div>

    <button type="submit" id="submitBtn" class="btn btn-gradient w-100"><i class="bi bi-save me-2"></i><%= editing ? 'Salvar artigo' : 'Criar artigo' %></button>
  </form>
</div>

<style>
  .ql-toolbar { background: var(--surface-2); border-color: var(--border) !important; border-radius: 8px 8px 0 0; }
  .ql-container { border-color: var(--border) !important; font-family: 'Roboto', sans-serif; font-size: 1rem; }
  .ql-editor { color: var(--text); }
  .ql-snow .ql-stroke { stroke: var(--text); }
  .ql-snow .ql-fill { fill: var(--text); }
  .ql-snow .ql-picker { color: var(--text); }
</style>

<script>
  var quill = new Quill('#editor-container', {
    theme: 'snow',
    placeholder: 'Escreva seu artigo aqui...',
    modules: {
      toolbar: [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        ['blockquote', 'code-block'],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        ['link', 'image'],
        ['clean']
      ]
    }
  });

  document.querySelector('.ajax-form').addEventListener('submit', function() {
    document.getElementById('body').value = quill.root.innerHTML;
  });
</script>

<%- include('fragments/footer') %>
