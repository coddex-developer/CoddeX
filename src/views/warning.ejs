<!DOCTYPE html>
<html lang="pt-br">

<head>
  <%- include('fragments/head', { pageTitle: title + ' · CoddeX' }) %>
</head>

<body>
  <!-- Fallback sem JavaScript -->
  <noscript>
    <div class="container d-flex justify-content-center align-items-center min-vh-100">
      <div class="glass text-center p-4" style="max-width: 420px;">
        <h1 class="h3 gradient-text mb-2"><%= title %></h1>
        <p class="text-muted-2"><%= info %></p>
        <a class="btn btn-gradient px-4 mt-2" href="<%= url %>"><%= textButton %></a>
      </div>
    </div>
  </noscript>

  <script>
    (function () {
      const go = function () { window.location.href = <%- JSON.stringify(url) %>; };
      function show() {
        Swal.fire({
          background: "#12131d",
          color: "#e8eaf2",
          confirmButtonColor: "#7c3aed",
          title: <%- JSON.stringify(title) %>,
          text: <%- JSON.stringify(info) %>,
          icon: <%- JSON.stringify(typeof icon !== 'undefined' ? icon : 'info') %>,
          confirmButtonText: <%- JSON.stringify(textButton) %>,
          allowOutsideClick: false
        }).then(go);
      }
      if (typeof Swal !== "undefined") show();
      else window.addEventListener("load", show);
    })();
  </script>
</body>

</html>
