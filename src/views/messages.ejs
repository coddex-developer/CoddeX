<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 1000px;">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar ao Painel
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Todas as Mensagens</h1>
      <p class="text-muted mb-0">Histórico completo de contatos via formulário do site.</p>
    </div>
    <div>
      <a href="/admin/dashboard/unread" class="btn btn-outline-warning px-4 py-2 rounded-pill shadow-sm">
        <i class="bi bi-envelope-exclamation me-2"></i>Ver Apenas Pendentes
      </a>
    </div>
  </div>

  <div class="row g-4">
    <% if (resultMessage && resultMessage.length > 0) { %>
      <% resultMessage.forEach(function(note) { %>
        <div class="col-12 col-md-6">
          <div class="card h-100 border-0 glass-panel overflow-hidden" style="border-radius: var(--radius-lg); border-left: 4px solid <%= note.completed ? 'var(--success)' : 'var(--warning)' %> !important;">
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="d-flex align-items-center">
                  <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px; background: rgba(255,255,255,0.05); color: var(--text-muted);">
                    <i class="bi bi-person-fill fs-5"></i>
                  </div>
                  <div>
                    <h6 class="mb-0 fw-bold text-white"><%= note.name %></h6>
                    <small class="text-muted"><%= note.email %></small>
                  </div>
                </div>
                <div>
                  <% if (!note.completed) { %>
                    <span class="badge bg-warning text-white rounded-pill px-3 py-1 shadow-sm" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">Pendente</span>
                  <% } else { %>
                    <span class="badge bg-success text-white rounded-pill px-3 py-1 shadow-sm" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">Concluído</span>
                  <% } %>
                </div>
              </div>
              
              <div class="p-3 rounded-3 mt-3 mb-4" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05);">
                <p class="mb-0 text-white" style="font-size: 0.95rem; line-height: 1.5;"><%= note.message %></p>
              </div>
            </div>
            
            <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center p-3" style="background: var(--surface-solid) !important;">
              <small class="text-muted"><i class="bi bi-clock me-1"></i><%= note.createdAt.toLocaleDateString('pt-BR') %></small>
              
              <div class="d-flex gap-2">
                <% if (!note.completed) { %>
                  <form action="/admin/dashboard/messages/<%= note.id %>/complete" method="post" class="m-0 ajax-form">
                    <button class="btn btn-outline-success btn-sm rounded-pill px-3" type="submit"><i class="bi bi-check2-circle me-1"></i>Marcar Concluído</button>
                  </form>
                <% } else { %>
                  <form action="/admin/dashboard/messages/<%= note.id %>/incomplete" method="post" class="m-0 ajax-form">
                    <button class="btn btn-outline-warning btn-sm rounded-pill px-3" type="submit"><i class="bi bi-arrow-counterclockwise me-1"></i>Reabrir</button>
                  </form>
                <% } %>
                
                <form action="/admin/dashboard/messages/<%= note.id %>/delete" method="post" class="m-0 ajax-form" data-confirm="Excluir esta mensagem permanentemente?" data-confirm-title="Excluir Mensagem" data-confirm-btn="Excluir">
                  <button class="btn btn-outline-danger btn-sm rounded-pill px-3" type="submit"><i class="bi bi-trash3-fill"></i></button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12">
        <div class="glass-panel p-5 text-center border-0">
          <i class="bi bi-inbox text-muted mb-3 d-block" style="font-size: 3rem;"></i>
          <h5 class="text-white fw-bold">Caixa de Entrada Vazia</h5>
          <p class="text-muted mb-0">Nenhuma mensagem foi recebida ainda.</p>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('fragments/footer') %>