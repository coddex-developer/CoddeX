<%- include('fragments/header') %>

<div class="container my-5">
  <!-- Boas-vindas -->
  <div class="glass p-4 mb-4 d-flex align-items-center gap-3">
    <i class="bi bi-person-circle display-5 gradient-text"></i>
    <div>
      <h1 class="h4 mb-1">Bem-vindo de volta, <%= adminUser.userAdmin %>!</h1>
      <p class="text-muted-2 mb-0">Gerencie seu site a partir do painel abaixo.</p>
    </div>
  </div>

  <!-- Cards de opções -->
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    <div class="col">
      <div class="card text-center h-100 p-2">
        <div class="card-body">
          <i class="bi bi-envelope-exclamation-fill display-5 mb-3" style="color: var(--warning);"></i>
          <h5 class="card-title fw-bold">Novas mensagens</h5>
          <p class="text-secondary"><%= unreadMessage.length %> pendente(s)</p>
          <a href="/admin/dashboard/unread" class="btn btn-gradient w-100">Ver mensagens</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card text-center h-100 p-2">
        <div class="card-body">
          <i class="bi bi-chat-left-text-fill display-5 mb-3" style="color: var(--info);"></i>
          <h5 class="card-title fw-bold">Todas as mensagens</h5>
          <p class="text-secondary"><%= resultMessage.length %> no total</p>
          <a href="/admin/dashboard/messages" class="btn btn-gradient w-100">Ver todas</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card text-center h-100 p-2">
        <div class="card-body">
          <i class="bi bi-chat-dots-fill display-5 mb-3" style="color: var(--accent-2, #22d3ee);"></i>
          <h5 class="card-title fw-bold">Conversas</h5>
          <p class="text-secondary">Tickets dos usuários</p>
          <a href="/admin/dashboard/tickets" class="btn btn-gradient w-100">Abrir</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card text-center h-100 p-2">
        <div class="card-body">
          <i class="bi bi-pencil-square display-5 mb-3" style="color: var(--success);"></i>
          <h5 class="card-title fw-bold">Editar o site</h5>
          <p class="text-secondary">Conteúdo, projetos e redes</p>
          <a href="/admin/dashboard/editPage" class="btn btn-gradient w-100">Editar</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card text-center h-100 p-2">
        <div class="card-body">
          <i class="bi bi-gear-fill display-5 mb-3 gradient-text"></i>
          <h5 class="card-title fw-bold">Perfil</h5>
          <p class="text-secondary">Credenciais do administrador</p>
          <a href="/admin/dashboard/adminProfile" class="btn btn-gradient w-100">Configurar</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('fragments/footer') %>
