<% if (!isAdmin) { %>
<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('fragments/head', { pageTitle: 'Minhas conversas · CoddeX' }) %>
</head>
<body class="d-flex flex-column min-vh-100" style="background: var(--bg);">
  <div class="container-fluid py-4 flex-grow-1">
    <div class="row gx-4">
      <div class="col-md-4 col-lg-3">
        <%- include('fragments/accountSidebar', { user: currentUser, currentPath: '/account/tickets' }) %>
      </div>
      <div class="col-md-8 col-lg-9 mt-4 mt-md-0">
<% } else { %>
  <%- include('fragments/header') %>
<% } %>

<div class="container<%= isAdmin ? ' py-5' : '' %>" style="max-width: <%= isAdmin ? '900px' : '100%' %>;">
  <!-- Cabeçalho -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="mb-3 mb-md-0">
      <% if (isAdmin) { %>
        <a href="/admin/dashboard" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
          <i class="bi bi-arrow-left me-1"></i> Voltar ao Painel
        </a>
      <% } %>
      <h1 class="h3 fw-bold mb-1 text-white"><%= isAdmin ? 'Central de Suporte (Tickets)' : 'Minhas Conversas' %></h1>
      <p class="text-muted mb-0"><%= isAdmin ? 'Gerencie as conversas ao vivo e chamados abertos.' : 'Acompanhe seus chamados de suporte e mensagens.' %></p>
    </div>
  </div>

  <div class="glass-panel border-0 overflow-hidden">
    <% if (tickets && tickets.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-dark table-hover mb-0" style="background: transparent;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border-strong);">
              <th scope="col" class="py-3 px-4 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Ticket / Usuário</th>
              <th scope="col" class="py-3 px-4 text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Última Mensagem</th>
              <th scope="col" class="py-3 px-4 text-muted text-uppercase text-center" style="font-size: 0.75rem; letter-spacing: 1px;">Status</th>
              <th scope="col" class="py-3 px-4 text-end text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Ação</th>
            </tr>
          </thead>
          <tbody>
            <% tickets.forEach(ticket => { %>
              <tr style="border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.2s;" onclick="window.location.href='/admin/dashboard/tickets/<%= ticket._id %>'" class="ticket-row">
                <td class="py-3 px-4 align-middle">
                  <div class="d-flex align-items-center">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background: rgba(138, 43, 226, 0.1); border: 1px solid rgba(138, 43, 226, 0.2); color: var(--accent-1);">
                      <i class="bi bi-chat-dots-fill"></i>
                    </div>
                    <div>
                      <span class="d-block fw-bold text-white"><%= ticket.userId ? ticket.userId.name : 'Usuário Anônimo' %></span>
                      <small class="text-muted"><%= new Date(ticket.updatedAt).toLocaleString('pt-BR') %></small>
                    </div>
                  </div>
                </td>
                <td class="py-3 px-4 align-middle text-muted" style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                  <span class="text-white"><%= ticket.subject %></span>
                </td>
                <td class="py-3 px-4 align-middle text-center">
                  <% if(ticket.status === 'open') { %>
                    <span class="badge bg-warning bg-opacity-25 text-warning rounded-pill px-3 py-1 border border-warning border-opacity-50">Aberto</span>
                  <% } else { %>
                    <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-3 py-1 border border-success border-opacity-50">Resolvido</span>
                  <% } %>
                </td>
                <td class="py-3 px-4 align-middle text-end">
                  <a href="/admin/dashboard/tickets/<%= ticket._id %>" class="btn btn-outline-light btn-sm rounded-pill px-3">
                    Abrir <i class="bi bi-arrow-right ms-1"></i>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="p-5 text-center">
        <i class="bi bi-chat-square-text text-muted mb-3" style="font-size: 3rem;"></i>
        <h5 class="text-white fw-bold">Nenhum Ticket Aberto</h5>
        <p class="text-muted">A central de suporte está vazia no momento.</p>
      </div>
    <% } %>
  </div>
</div>

</div>

<style>
  .ticket-row:hover {
    background: rgba(255, 255, 255, 0.03) !important;
  }
</style>

<% if (!isAdmin) { %>
      </div>
    </div>
  </div>
</body>
</html>
<% } else { %>
  <%- include('fragments/footer') %>
<% } %>
