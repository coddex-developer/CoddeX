<% if (isAdmin) { %>
  <%- include('fragments/header') %>
<% } else { %>
<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('fragments/head', { pageTitle: 'Minhas conversas · CoddeX' }) %>
</head>
<body class="d-flex flex-column min-vh-100">
  <nav class="navbar sticky-top" data-bs-theme="dark">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <img src="/assets/admin1.png" alt="CoddeX" style="max-height: 38px;">
        <span class="fw-bold gradient-text d-none d-sm-inline">CoddeX</span>
      </a>
      <div class="d-flex align-items-center gap-2">
        <a href="/account" class="btn btn-outline-light btn-sm"><i class="bi bi-person-circle me-1"></i>Conta</a>
        <a href="/logout" class="btn btn-outline-light btn-sm text-danger"><i class="bi bi-box-arrow-right me-1"></i>Sair</a>
      </div>
    </div>
  </nav>
  <div class="flex-grow-1">
<% } %>

  <div class="container py-5" style="max-width: 760px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0"><i class="bi bi-chat-dots-fill me-2 gradient-text"></i><%= isAdmin ? 'Conversas' : 'Minhas conversas' %></h1>
      <a href="<%= isAdmin ? '/admin/dashboard' : '/account' %>" class="btn btn-outline-light btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
      </a>
    </div>

    <% if (!isAdmin) { %>
      <!-- Nova conversa -->
      <form action="/account/tickets" method="post" class="glass p-4 mb-4">
        <h2 class="h6 mb-3">Iniciar nova conversa</h2>
        <div class="mb-2">
          <input type="text" class="form-control" name="subject" maxlength="140" placeholder="Assunto" required>
        </div>
        <div class="mb-2">
          <textarea class="form-control" name="body" rows="3" placeholder="Escreva sua mensagem (suporta markdown)..." required></textarea>
        </div>
        <button class="btn btn-gradient" type="submit"><i class="bi bi-send me-1"></i>Enviar</button>
      </form>
    <% } %>

    <% if (tickets.length === 0) { %>
      <div class="glass p-4 text-muted-2 text-center">Nenhuma conversa ainda.</div>
    <% } else { %>
      <div class="d-flex flex-column gap-2">
        <% tickets.forEach(t => { %>
          <a href="<%= isAdmin ? '/admin/dashboard/tickets/' : '/account/tickets/' %><%= t._id %>"
             class="glass p-3 d-flex align-items-center gap-3 text-decoration-none ticket-row">
            <i class="bi bi-chat-left-text fs-4 gradient-text"></i>
            <div class="flex-grow-1 min-w-0">
              <div class="d-flex align-items-center gap-2">
                <strong class="text-truncate"><%= t.subject %></strong>
                <% if (t.status === 'closed') { %><span class="badge bg-secondary">fechado</span><% } %>
              </div>
              <% if (isAdmin) { %><small class="text-muted-2"><%= t.userName %> · <%= t.userEmail %></small><% } %>
              <small class="text-muted-2 d-block"><%= new Date(t.lastMessageAt).toLocaleString('pt-BR') %></small>
            </div>
            <% if (t.unread > 0) { %>
              <span class="badge rounded-pill bg-danger"><%= t.unread %></span>
            <% } %>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>

<% if (isAdmin) { %>
  <%- include('fragments/footer') %>
<% } else { %>
  </div>
  <footer class="text-center py-3 mt-auto"><small>&copy; <%= new Date().getFullYear() %> · CoddeX Developer</small></footer>
</body>
</html>
<% } %>
