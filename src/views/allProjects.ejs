<%- include('fragments/header') %>

<div class="container py-5" style="max-width: 1100px;">
  <!-- Cabeçalho Principal -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
    <div class="mb-3 mb-md-0">
      <a href="/admin/dashboard/editPage" class="text-muted text-decoration-none small d-flex align-items-center mb-2">
        <i class="bi bi-arrow-left me-1"></i> Voltar aos Ajustes
      </a>
      <h1 class="h3 fw-bold mb-1 text-white">Projetos Publicados</h1>
      <p class="text-muted mb-0">Gerencie os projetos que compõem o seu portfólio.</p>
    </div>
    <div>
      <a href="/admin/dashboard/editPage/CreateProjects" class="btn btn-gradient px-4 py-2 shadow-glow">
        <i class="bi bi-plus-lg me-2"></i>Novo Projeto
      </a>
    </div>
  </div>

  <div class="row g-4">
    <% if (projects && projects.length > 0) { %>
      <% projects.forEach(function(project) { %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card h-100 border-0 glass-panel overflow-hidden" style="border-radius: var(--radius-lg); transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <!-- Imagem do Projeto (Cover) -->
            <div class="position-relative" style="height: 200px; overflow: hidden;">
              <img src="<%= project.imagePj %>" class="w-100 h-100" style="object-fit: cover; transition: transform 0.5s ease;" alt="<%= project.titlePj %>" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
              <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.8) 100%);"></div>
              <h5 class="position-absolute bottom-0 start-0 m-3 mb-2 text-white fw-bold"><%= project.titlePj %></h5>
            </div>
            
            <!-- Ações -->
            <div class="card-footer bg-transparent border-0 d-flex gap-2 p-3" style="background: var(--surface-solid) !important;">
              <a href="/admin/dashboard/editPage/CreateProjects/allProjects/<%= project.id %>" class="btn btn-secondary flex-grow-1" style="border-radius: 8px;">
                <i class="bi bi-pencil-square me-1"></i>Editar
              </a>
              <form action="/admin/dashboard/editPage/CreateProjects/allProjects/<%= project.id %>" method="post"
                class="m-0 ajax-form" data-confirm="Tem certeza que deseja excluir permanentemente o projeto '<%= project.titlePj %>'? Esta ação não pode ser desfeita."
                data-confirm-title="Excluir Projeto" data-confirm-btn="Excluir">
                <button class="btn btn-outline-danger px-3 h-100" style="border-radius: 8px;" type="submit" title="Excluir Projeto">
                  <i class="bi bi-trash3-fill"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-12">
        <div class="glass-panel p-5 text-center border-0" style="background: rgba(0, 240, 255, 0.05);">
          <i class="bi bi-window-stack text-muted mb-3 d-block" style="font-size: 3rem; color: var(--accent-2) !important;"></i>
          <h5 class="text-white fw-bold">Seu Portfólio está Vazio</h5>
          <p class="text-muted mb-4">Você ainda não publicou nenhum projeto para exibição pública.</p>
          <a href="/admin/dashboard/editPage/CreateProjects" class="btn btn-outline-primary px-4">Adicionar o Primeiro Projeto</a>
        </div>
      </div>
    <% } %>    
  </div>
</div>

<style>
  .card.glass-panel:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.5), 0 0 15px rgba(0, 240, 255, 0.1) !important;
    border-color: rgba(0, 240, 255, 0.3) !important;
  }
</style>

<%- include('fragments/footer') %>