# Porta em que a aplicação vai rodar
PORT=3000

# Ambiente: "production" ativa o cookie de sessão seguro (HTTPS)
NODE_ENV=development

# String de conexão do MongoDB.
# - Local (docker-compose): mongodb://mongo:27017/coddex
# - Atlas: mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/coddex
MONGODB_URI=mongodb://mongo:27017/coddex

# Chave secreta usada para assinar a sessão (use um valor longo e aleatório)
SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# Credenciais do administrador criado automaticamente no primeiro start
ADMIN_USER=admin
ADMIN_PASS=troque-esta-senha
ADMIN_PHONE=

# ---------------------------------------------------------------
# Envio de e-mail (verificação de conta e notificações)
# Se MAIL_USER e MAIL_PASS ficarem vazios, o sistema roda em modo
# de desenvolvimento: o código de verificação é exibido no console
# (nenhum e-mail real é enviado).
# ---------------------------------------------------------------
# Gmail (use uma "senha de app", não a senha normal): deixe MAIL_HOST vazio
# Outro SMTP: preencha MAIL_HOST, MAIL_PORT e MAIL_SECURE
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=CoddeX <no-reply@coddex.store>

# Cloudinary (upload de imagens). Opcional aqui — também pode ser configurado
# pelo painel admin em "Configurar site" (o painel tem prioridade sobre o .env).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
