# Porta em que a aplicação vai rodar
PORT=3000

# Ambiente: "production" ativa o cookie de sessão seguro (HTTPS)
NODE_ENV=development

# String de conexão do MongoDB.
# - Local (docker-compose): mongodb://mongo:27017/coddex
# - Atlas: mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/coddex
MONGODB_URI=mongodb://mongo:27017/coddex

# Chave secreta usada para assinar a sessão (use um valor longo e aleatório)
SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# Credenciais do administrador criado automaticamente no primeiro start
ADMIN_USER=admin
ADMIN_PASS=troque-esta-senha
ADMIN_PHONE=
